$C = "../Common.ui";
$Nav = "Nav/LeftNavPanel.ui";

@CustomStyle = TextButtonStyle(
    Default: (Background: $C.@DefaultSquareButtonDefaultBackground, LabelStyle: $C.@DefaultButtonLabelStyle),
    Hovered: (Background: $C.@DefaultSquareButtonHoveredBackground, LabelStyle: $C.@DefaultButtonLabelStyle),
    Pressed: (Background: $C.@DefaultSquareButtonPressedBackground, LabelStyle: $C.@DefaultButtonLabelStyle),
    Disabled: (Background: $C.@DefaultSquareButtonDisabledBackground, LabelStyle: $C.@DefaultButtonDisabledLabelStyle),
    Sounds: $C.@ButtonSounds,
);

@ButtonClusterWidth = 180;
@SettingValueWidth = 96;
@ToggleButtonWidth = 118;

$C.@PageOverlay {
    $C.@DecoratedContainer {
        Anchor: (Width: 1000, Height: 700);
        #Title {
            Group {
                $C.@Title {
                    @Text = "ENDLESS LEVELING";
                }
            }
        }

        #Content {
            LayoutMode: Left;
            Padding: (Full: 0);

            // ================= LEFT PANEL =================
            $Nav.@LeftNavPanel {}
            
            // ================= RIGHT PANEL =================
            Group #RightPanel {
                FlexWeight: 1;
                LayoutMode: Top;
                Anchor: (Right: 7, Bottom: 7);

                // -------- Title --------
                Group #Header {
                    LayoutMode: Left;
                    Anchor: (Height: 60);
                    Padding: (Horizontal: 16, Vertical: 10);

                    Label #SettingsTitleLabel {
                        Text: "Settings";
                        Anchor: (Height: 60);
                        Style: (FontSize: 22, TextColor: #ffffff, RenderBold: true, VerticalAlignment: Center);
                    }

                    Group { FlexWeight: 1; }

                    Group #SettingsIntro {
                        LayoutMode: Left;
                        Background: #0b141f(0.92);
                        Anchor: (Height: 40);
                        Padding: (Full: 8);

                        Label #SettingsIntroText {
                            Style: (TextColor: #aaccff, FontSize: 14, VerticalAlignment: Center);
                            Text: "Manage personal HUD, notifications, and visual preferences.";
                        }
                    }
                }

                Group {
                    Anchor: (Height: 1);
                    Background: #2b3542;
                }

                // -------- OPTIONS --------
                Group #Main {
                    LayoutMode: TopScrolling;
                    ScrollbarStyle: $C.@DefaultScrollbarStyle;
                    FlexWeight: 1;
                    Padding: (Full: 16);

                    Group #SettingsList {
                        LayoutMode: Top;

                        Group #PlayerHudRow {
                            LayoutMode: Left;
                            Background: #0b141f(0.84);
                            Padding: (Full: 12);

                            Group {
                                LayoutMode: Top;
                                FlexWeight: 1;

                                Group {
                                    LayoutMode: Left;

                                    Label #PlayerHudLabel { Style: (TextColor: #f4f9ff, FontSize: 16, RenderBold: true); FlexWeight: 1; Text: "Player HUD"; }

                                    Label #PlayerHudValue {
                                        Text: "ON";
                                        Anchor: (Width: @SettingValueWidth, Height: 24);
                                        Padding: (Horizontal: 8, Vertical: 4);
                                        Style: (TextColor: #6fe3ff, FontSize: 12, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
                                        Background: #061420;
                                    }
                                }

                                Group { Anchor: (Height: 4); }

                                Label #PlayerHudDescription {
                                    Text: "Show or hide the Endless Leveling HUD overlay.";
                                    Style: (TextColor: #c0cee5, FontSize: 12);
                                }
                            }

                            Group { Anchor: (Width: 12); }

                            $C.@TextButton #PlayerHudToggle {
                                Anchor: (Height: 32, Width: @ToggleButtonWidth);
                                Padding: (Horizontal: 8, Vertical: 4);
                                Text: "Toggle";
                                Style: @CustomStyle;
                            }
                        }

                        Group { Anchor: (Height: 10); }

                        Group #CriticalNotifRow {
                            LayoutMode: Left;
                            Background: #0b141f(0.84);
                            Padding: (Full: 12);

                            Group {
                                LayoutMode: Top;
                                FlexWeight: 1;

                                Group {
                                    LayoutMode: Left;

                                    Label #CriticalNotifLabel { Style: (TextColor: #f4f9ff, FontSize: 16, RenderBold: true); FlexWeight: 1; Text: "Critical Hit Notifications"; }

                                    Label #CriticalNotifValue {
                                        Text: "ON";
                                        Anchor: (Width: @SettingValueWidth, Height: 24);
                                        Padding: (Horizontal: 8, Vertical: 4);
                                        Style: (TextColor: #6fe3ff, FontSize: 12, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
                                        Background: #061420;
                                    }
                                }

                                Group { Anchor: (Height: 4); }

                                Label #CriticalNotifDescription {
                                    Text: "Toggle floating alerts for critical strike events.";
                                    Style: (TextColor: #c0cee5, FontSize: 12);
                                }
                            }

                            Group { Anchor: (Width: 12); }

                            $C.@TextButton #CriticalNotifToggle {
                                Anchor: (Height: 32, Width: @ToggleButtonWidth);
                                Padding: (Horizontal: 8, Vertical: 4);
                                Text: "Toggle";
                                Style: @CustomStyle;
                            }
                        }

                        Group { Anchor: (Height: 10); }

                        Group #XpNotifRow {
                            LayoutMode: Left;
                            Background: #0b141f(0.84);
                            Padding: (Full: 12);

                            Group {
                                LayoutMode: Top;
                                FlexWeight: 1;

                                Group {
                                    LayoutMode: Left;

                                    Label #XpNotifLabel { Style: (TextColor: #f4f9ff, FontSize: 16, RenderBold: true); FlexWeight: 1; Text: "XP Gain Notifications"; }

                                    Label #XpNotifValue {
                                        Text: "ON";
                                        Anchor: (Width: @SettingValueWidth, Height: 24);
                                        Padding: (Horizontal: 8, Vertical: 4);
                                        Style: (TextColor: #6fe3ff, FontSize: 12, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
                                        Background: #061420;
                                    }
                                }

                                Group { Anchor: (Height: 4); }

                                Label #XpNotifDescription {
                                    Text: "Show notifications whenever you gain experience.";
                                    Style: (TextColor: #c0cee5, FontSize: 12);
                                }
                            }

                            Group { Anchor: (Width: 12); }

                            $C.@TextButton #XpNotifToggle {
                                Anchor: (Height: 32, Width: @ToggleButtonWidth);
                                Padding: (Horizontal: 8, Vertical: 4);
                                Text: "Toggle";
                                Style: @CustomStyle;
                            }
                        }

                        Group { Anchor: (Height: 10); }

                        Group #PassiveLevelUpNotifRow {
                            LayoutMode: Left;
                            Background: #0b141f(0.84);
                            Padding: (Full: 12);

                            Group {
                                LayoutMode: Top;
                                FlexWeight: 1;

                                Group {
                                    LayoutMode: Left;

                                    Label #PassiveLevelUpNotifLabel { Style: (TextColor: #f4f9ff, FontSize: 16, RenderBold: true); FlexWeight: 1; Text: "Passive Level-Up Notifications"; }

                                    Label #PassiveLevelUpNotifValue {
                                        Text: "ON";
                                        Anchor: (Width: @SettingValueWidth, Height: 24);
                                        Padding: (Horizontal: 8, Vertical: 4);
                                        Style: (TextColor: #6fe3ff, FontSize: 12, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
                                        Background: #061420;
                                    }
                                }

                                Group { Anchor: (Height: 4); }

                                Label #PassiveLevelUpNotifDescription {
                                    Text: "Display updates when passives rank up during play.";
                                    Style: (TextColor: #c0cee5, FontSize: 12);
                                }
                            }

                            Group { Anchor: (Width: 12); }

                            $C.@TextButton #PassiveLevelUpNotifToggle {
                                Anchor: (Height: 32, Width: @ToggleButtonWidth);
                                Padding: (Horizontal: 8, Vertical: 4);
                                Text: "Toggle";
                                Style: @CustomStyle;
                            }
                        }

                        Group { Anchor: (Height: 10); }

                        Group #LuckDoubleDropsNotifRow {
                            LayoutMode: Left;
                            Background: #0b141f(0.84);
                            Padding: (Full: 12);

                            Group {
                                LayoutMode: Top;
                                FlexWeight: 1;

                                Group {
                                    LayoutMode: Left;

                                    Label #LuckDoubleDropsNotifLabel { Style: (TextColor: #f4f9ff, FontSize: 16, RenderBold: true); FlexWeight: 1; Text: "Luck Double-Drop Notifications"; }

                                    Label #LuckDoubleDropsNotifValue {
                                        Text: "ON";
                                        Anchor: (Width: @SettingValueWidth, Height: 24);
                                        Padding: (Horizontal: 8, Vertical: 4);
                                        Style: (TextColor: #6fe3ff, FontSize: 12, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
                                        Background: #061420;
                                    }
                                }

                                Group { Anchor: (Height: 4); }

                                Label #LuckDoubleDropsNotifDescription {
                                    Text: "Toggle bonus drop proc notifications from luck effects.";
                                    Style: (TextColor: #c0cee5, FontSize: 12);
                                }
                            }

                            Group { Anchor: (Width: 12); }

                            $C.@TextButton #LuckDoubleDropsNotifToggle {
                                Anchor: (Height: 32, Width: @ToggleButtonWidth);
                                Padding: (Horizontal: 8, Vertical: 4);
                                Text: "Toggle";
                                Style: @CustomStyle;
                            }
                        }

                        Group { Anchor: (Height: 10); }

                        Group #HealthRegenNotifRow {
                            LayoutMode: Left;
                            Background: #0b141f(0.84);
                            Padding: (Full: 12);

                            Group {
                                LayoutMode: Top;
                                FlexWeight: 1;

                                Group {
                                    LayoutMode: Left;

                                    Label #HealthRegenNotifLabel { Style: (TextColor: #f4f9ff, FontSize: 16, RenderBold: true); FlexWeight: 1; Text: "Health Regen Notifications"; }

                                    Label #HealthRegenNotifValue {
                                        Text: "ON";
                                        Anchor: (Width: @SettingValueWidth, Height: 24);
                                        Padding: (Horizontal: 8, Vertical: 4);
                                        Style: (TextColor: #6fe3ff, FontSize: 12, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
                                        Background: #061420;
                                    }
                                }

                                Group { Anchor: (Height: 4); }

                                Label #HealthRegenNotifDescription {
                                    Text: "Show notifications when health regeneration triggers.";
                                    Style: (TextColor: #c0cee5, FontSize: 12);
                                }
                            }

                            Group { Anchor: (Width: 12); }

                            $C.@TextButton #HealthRegenNotifToggle {
                                Anchor: (Height: 32, Width: @ToggleButtonWidth);
                                Padding: (Horizontal: 8, Vertical: 4);
                                Text: "Toggle";
                                Style: @CustomStyle;
                            }
                        }

                        Group { Anchor: (Height: 10); }

                        Group #AugmentNotifRow {
                            LayoutMode: Left;
                            Background: #0b141f(0.84);
                            Padding: (Full: 12);

                            Group {
                                LayoutMode: Top;
                                FlexWeight: 1;

                                Group {
                                    LayoutMode: Left;

                                    Label #AugmentNotifLabel { Style: (TextColor: #f4f9ff, FontSize: 16, RenderBold: true); FlexWeight: 1; Text: "Augment Notifications"; }

                                    Label #AugmentNotifValue {
                                        Text: "ON";
                                        Anchor: (Width: @SettingValueWidth, Height: 24);
                                        Padding: (Horizontal: 8, Vertical: 4);
                                        Style: (TextColor: #6fe3ff, FontSize: 12, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
                                        Background: #061420;
                                    }
                                }

                                Group { Anchor: (Height: 4); }

                                Label #AugmentNotifDescription {
                                    Text: "Toggle chat notifications for augment status events.";
                                    Style: (TextColor: #c0cee5, FontSize: 12);
                                }
                            }

                            Group { Anchor: (Width: 12); }

                            $C.@TextButton #AugmentNotifToggle {
                                Anchor: (Height: 32, Width: @ToggleButtonWidth);
                                Padding: (Horizontal: 8, Vertical: 4);
                                Text: "Toggle";
                                Style: @CustomStyle;
                            }
                        }

                        Group { Anchor: (Height: 10); }

                        Group #RaceModelRow {
                            LayoutMode: Left;
                            Background: #0b141f(0.84);
                            Padding: (Full: 12);

                            Group {
                                LayoutMode: Top;
                                FlexWeight: 1;

                                Group {
                                    LayoutMode: Left;

                                    Label #RaceModelLabel { Style: (TextColor: #f4f9ff, FontSize: 16, RenderBold: true); FlexWeight: 1; Text: "Race Model Visuals"; }

                                    Label #RaceModelValue {
                                        Text: "ON";
                                        Anchor: (Width: @SettingValueWidth, Height: 24);
                                        Padding: (Horizontal: 8, Vertical: 4);
                                        Style: (TextColor: #6fe3ff, FontSize: 12, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
                                        Background: #061420;
                                    }
                                }

                                Group { Anchor: (Height: 4); }

                                Label #RaceModelDescription {
                                    Text: "Enable race-specific character visuals when available.";
                                    Style: (TextColor: #c0cee5, FontSize: 12);
                                }
                            }

                            Group { Anchor: (Width: 12); }

                            $C.@TextButton #RaceModelToggle {
                                Anchor: (Height: 32, Width: @ToggleButtonWidth);
                                Padding: (Horizontal: 8, Vertical: 4);
                                Text: "Toggle";
                                Style: @CustomStyle;
                            }
                        }
                    }
                }
            }
        }
    }
}

$C.@BackButton {}
