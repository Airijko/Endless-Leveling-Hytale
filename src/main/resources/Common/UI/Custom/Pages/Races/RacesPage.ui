$C = "../../Common.ui";
$Nav = "../Nav/LeftNavPanel.ui";

@CustomStyle = TextButtonStyle(
    Default: (Background: $C.@DefaultSquareButtonDefaultBackground, LabelStyle: $C.@DefaultButtonLabelStyle),
    Hovered: (Background: $C.@DefaultSquareButtonHoveredBackground, LabelStyle: $C.@DefaultButtonLabelStyle),
    Pressed: (Background: $C.@DefaultSquareButtonPressedBackground, LabelStyle: $C.@DefaultButtonLabelStyle),
    Disabled: (Background: $C.@DefaultSquareButtonDisabledBackground, LabelStyle: $C.@DefaultButtonDisabledLabelStyle),
    Sounds: $C.@ButtonSounds,
);

$C.@PageOverlay {
    Group {
        LayoutMode: Middle;

        Group {
            LayoutMode: Left;
            Anchor: (Width: 1680, Height: 700);

            Group {
                LayoutMode: Top;
                Anchor: (Width: 1680, Height: 700);

                Group {
                    LayoutMode: Middle;
                    Anchor: (Width: 1680);

                    Group {
                        LayoutMode: Left;

                        $C.@DecoratedContainer {
                            Anchor: (Width: 300, Height: 700);

                            #Title {
                                Group {
                                    $C.@Title #RacesListPanel { @Text = "RACES"; }
                                }
                            }

                            #Content {
                                LayoutMode: Top;
                                Padding: (Horizontal: 12, Bottom: 12);

                                Group #RaceListColumn {
                                    FlexWeight: 1;
                                    LayoutMode: Top;

                                    Group #RaceListHeader {
                                        LayoutMode: Left;
                                        Anchor: (Height: 32);
                                        Padding: (Vertical: 4);

                                        Label #RaceListTitle {
                                            Text: "Available Races";
                                            Style: (FontSize: 16, TextColor: #ffffff, RenderBold: true, VerticalAlignment: Center);
                                        }

                                        Group { FlexWeight: 1; }

                                        Label #RaceCountLabel {
                                            Text: "0 unlocked";
                                            Style: (FontSize: 12, TextColor: #9fb6d3, VerticalAlignment: Center);
                                            Anchor: (Height: 18);
                                        }
                                    }

                                    Group { Anchor: (Height: 10); }

                                    Group #RaceListScroll {
                                        FlexWeight: 1;
                                        LayoutMode: TopScrolling;
                                        ScrollbarStyle: $C.@DefaultScrollbarStyle;

                                        Group #RaceRows {
                                            LayoutMode: Top;
                                        }
                                    }
                                }
                            }
                        }

                        Group { Anchor: (Width: 40); }

                        $C.@DecoratedContainer {
                            Anchor: (Width: 1000, Height: 700);
                            #Title {
                                Group {
                                    $C.@Title {
                                        @Text = "ENDLESS LEVELING";
                                    }
                                }
                            }

                            #Content {
                                LayoutMode: Left;
                                Padding: (Full: 0);

                                // ---------------- LEFT NAV ----------------
                                $Nav.@LeftNavPanel {}

                                // ---------------- MAIN CONTENT ----------------
                                Group #LeftContent {
                                    FlexWeight: 1;
                                    LayoutMode: Top;
                                    Anchor: (Right: 7, Bottom: 7);

                                    Group #RaceContent {
                                        LayoutMode: Left;
                                        FlexWeight: 1;
                                        Padding: (Full: 16);

                                        Group #RaceDetailPanel {
                                            LayoutMode: Top;
                                            Anchor: (Width: 430);
                                            Background: #050910(0.85);
                                            Padding: (Left: 18, Right: 18, Top: 18, Bottom: 18);

                                            Label #SelectedRaceLabel {
                                                Text: "Select a Race";
                                                Style: (FontSize: 20, TextColor: #ffffff, RenderBold: true);
                                                Anchor: (Height: 24);
                                            }

                                            Label #SelectedRaceSubtitle {
                                                Text: "Choose a race on the left to preview identity, stats, and passives.";
                                                Style: (FontSize: 13, TextColor: #8aa1bf);
                                                Anchor: (Height: 18);
                                            }

                                            Group { Anchor: (Height: 14); }
                                            Group { Anchor: (Height: 1); Background: #ffffff(0.08); }
                                            Group { Anchor: (Height: 14); }

                                            Group { Anchor: (Height: 16); }

                                            Group #RaceDetailScrollArea {
                                                FlexWeight: 1;
                                                LayoutMode: TopScrolling;
                                                ScrollbarStyle: $C.@DefaultScrollbarStyle;

                                                Group #RaceDetailScrollContent {
                                                    LayoutMode: Top;

                                                    Label #RaceLoreTitle {
                                                        Text: "Lore Preview";
                                                        Style: (FontSize: 14, TextColor: #ffffff, RenderBold: true);
                                                        Anchor: (Height: 20);
                                                    }

                                                    Label #RaceLoreText {
                                                        Text: "Dive into the mythos behind this race.";
                                                        Style: (FontSize: 12, TextColor: #9fb6d3, Wrap: true);
                                                        Anchor: (Height: 48);
                                                        FlexWeight: 1;
                                                    }

                                                    Group { Anchor: (Height: 16); }

                                                    Label #RaceStatsTitle {
                                                        Text: "Race Stats";
                                                        Style: (FontSize: 14, TextColor: #ffffff, RenderBold: true);
                                                        Anchor: (Height: 20);
                                                    }

                                                    Group #RaceAttributeList {
                                                        LayoutMode: Top;
                                                        Background: #0b141f(0.7);
                                                        Padding: (Left: 14, Right: 14, Top: 10, Bottom: 10);

                                                        Group {
                                                            LayoutMode: Left;
                                                            Anchor: (Height: 20);
                                                            Label #RaceAttributeLifeForceLabel { Text: "Life Force"; Style: (FontSize: 12, TextColor: #7be0ff); }
                                                            Group { FlexWeight: 1; }
                                                            Label #RaceAttributeLifeForceValue { Text: "--"; Style: (FontSize: 12, TextColor: #4fd7f7, RenderBold: true); }
                                                            Group { Anchor: (Width: 8); }
                                                            Label #RaceAttributeLifeForceNote { Text: "--"; Style: (FontSize: 12, TextColor: #8aa1bf); }
                                                        }
                                                        Group {
                                                            LayoutMode: Left;
                                                            Anchor: (Height: 20);
                                                            Label #RaceAttributeStrengthLabel { Text: "Strength"; Style: (FontSize: 12, TextColor: #ffb347); }
                                                            Group { FlexWeight: 1; }
                                                            Label #RaceAttributeStrengthValue { Text: "--"; Style: (FontSize: 12, TextColor: #ffdf8f, RenderBold: true); }
                                                            Group { Anchor: (Width: 8); }
                                                            Label #RaceAttributeStrengthNote { Text: "--"; Style: (FontSize: 12, TextColor: #8aa1bf); }
                                                        }
                                                        Group {
                                                            LayoutMode: Left;
                                                            Anchor: (Height: 20);
                                                            Label #RaceAttributeSorceryLabel { Text: "Sorcery"; Style: (FontSize: 12, TextColor: #d7baff); }
                                                            Group { FlexWeight: 1; }
                                                            Label #RaceAttributeSorceryValue { Text: "--"; Style: (FontSize: 12, TextColor: #e8d5ff, RenderBold: true); }
                                                            Group { Anchor: (Width: 8); }
                                                            Label #RaceAttributeSorceryNote { Text: "--"; Style: (FontSize: 12, TextColor: #8aa1bf); }
                                                        }
                                                        Group {
                                                            LayoutMode: Left;
                                                            Anchor: (Height: 20);
                                                            Label #RaceAttributeDefenseLabel { Text: "Defense"; Style: (FontSize: 12, TextColor: #8be0b2); }
                                                            Group { FlexWeight: 1; }
                                                            Label #RaceAttributeDefenseValue { Text: "--"; Style: (FontSize: 12, TextColor: #6ee7b7, RenderBold: true); }
                                                            Group { Anchor: (Width: 8); }
                                                            Label #RaceAttributeDefenseNote { Text: "--"; Style: (FontSize: 12, TextColor: #8aa1bf); }
                                                        }
                                                        Group {
                                                            LayoutMode: Left;
                                                            Anchor: (Height: 20);
                                                            Label #RaceAttributeHasteLabel { Text: "Haste"; Style: (FontSize: 12, TextColor: #f2a2e8); }
                                                            Group { FlexWeight: 1; }
                                                            Label #RaceAttributeHasteValue { Text: "--"; Style: (FontSize: 12, TextColor: #f78bd9, RenderBold: true); }
                                                            Group { Anchor: (Width: 8); }
                                                            Label #RaceAttributeHasteNote { Text: "--"; Style: (FontSize: 12, TextColor: #8aa1bf); }
                                                        }
                                                        Group {
                                                            LayoutMode: Left;
                                                            Anchor: (Height: 20);
                                                            Label #RaceAttributePrecisionLabel { Text: "Precision"; Style: (FontSize: 12, TextColor: #9ad4ff); }
                                                            Group { FlexWeight: 1; }
                                                            Label #RaceAttributePrecisionValue { Text: "--"; Style: (FontSize: 12, TextColor: #7cb8ff, RenderBold: true); }
                                                            Group { Anchor: (Width: 8); }
                                                            Label #RaceAttributePrecisionNote { Text: "--"; Style: (FontSize: 12, TextColor: #8aa1bf); }
                                                        }
                                                        Group {
                                                            LayoutMode: Left;
                                                            Anchor: (Height: 20);
                                                            Label #RaceAttributeFerocityLabel { Text: "Ferocity"; Style: (FontSize: 12, TextColor: #ff7b7b); }
                                                            Group { FlexWeight: 1; }
                                                            Label #RaceAttributeFerocityValue { Text: "--"; Style: (FontSize: 12, TextColor: #ff5555, RenderBold: true); }
                                                            Group { Anchor: (Width: 8); }
                                                            Label #RaceAttributeFerocityNote { Text: "--"; Style: (FontSize: 12, TextColor: #8aa1bf); }
                                                        }
                                                        Group {
                                                            LayoutMode: Left;
                                                            Anchor: (Height: 20);
                                                            Label #RaceAttributeStaminaLabel { Text: "Stamina"; Style: (FontSize: 12, TextColor: #ffc56f); }
                                                            Group { FlexWeight: 1; }
                                                            Label #RaceAttributeStaminaValue { Text: "--"; Style: (FontSize: 12, TextColor: #ffad42, RenderBold: true); }
                                                            Group { Anchor: (Width: 8); }
                                                            Label #RaceAttributeStaminaNote { Text: "--"; Style: (FontSize: 12, TextColor: #8aa1bf); }
                                                        }
                                                        Group {
                                                            LayoutMode: Left;
                                                            Anchor: (Height: 20);
                                                            Label #RaceAttributeFlowLabel { Text: "Flow"; Style: (FontSize: 12, TextColor: #9be3ff); }
                                                            Group { FlexWeight: 1; }
                                                            Label #RaceAttributeFlowValue { Text: "--"; Style: (FontSize: 12, TextColor: #7dd6ff, RenderBold: true); }
                                                            Group { Anchor: (Width: 8); }
                                                            Label #RaceAttributeFlowNote { Text: "--"; Style: (FontSize: 12, TextColor: #8aa1bf); }
                                                        }
                                                        Group {
                                                            LayoutMode: Left;
                                                            Anchor: (Height: 20);
                                                            Label #RaceAttributeDisciplineLabel { Text: "Discipline"; Style: (FontSize: 12, TextColor: #d5dfff); }
                                                            Group { FlexWeight: 1; }
                                                            Label #RaceAttributeDisciplineValue { Text: "--"; Style: (FontSize: 12, TextColor: #9fe0ff, RenderBold: true); }
                                                            Group { Anchor: (Width: 8); }
                                                            Label #RaceAttributeDisciplineNote { Text: "--"; Style: (FontSize: 12, TextColor: #8aa1bf); }
                                                        }
                                                    }

                                                    Group { Anchor: (Height: 16); }

                                                    Label #RacePassivesTitle {
                                                        Text: "Passives";
                                                        Style: (FontSize: 14, TextColor: #ffffff, RenderBold: true);
                                                        Anchor: (Height: 20);
                                                    }

                                                    Label #RacePassiveSummary {
                                                        Text: "Inspect a race to preview its passive bonuses.";
                                                        Style: (FontSize: 12, TextColor: #9fb6d3, RenderBold: true);
                                                        Anchor: (Height: 18);
                                                    }

                                                    Group #RacePassiveEntries {
                                                        LayoutMode: Top;
                                                    }
                                                }
                                            }
                                        }

                                        Group { Anchor: (Width: 16); }

                                        Group #RightContent {
                                            LayoutMode: Top;
                                            FlexWeight: 1;
                                            Background: #050910(0.85);
                                            Padding: (Left: 16, Right: 16, Top: 16, Bottom: 16);

                                            Label #RaceEvolutionTitle {
                                                Text: "Evolution Paths";
                                                Style: (FontSize: 16, TextColor: #ffffff, RenderBold: true);
                                                Anchor: (Height: 22);
                                            }

                                            Label #RaceEvolutionSummary {
                                                Text: "Select a race to inspect evolution branches.";
                                                Style: (FontSize: 12, TextColor: #9fb6d3, RenderBold: true, Wrap: true);
                                                Anchor: (Height: 48);
                                            }

                                            Group { Anchor: (Height: 10); }

                                            Group #RaceEvolutionScrollArea {
                                                FlexWeight: 1;
                                                LayoutMode: TopScrolling;
                                                ScrollbarStyle: $C.@DefaultScrollbarStyle;

                                                Group #RaceEvolutionEntries {
                                                    LayoutMode: Top;
                                                }
                                            }
                                        }
                                    }

                                    Group #RaceDetailActions {
                                        LayoutMode: Top;
                                        Padding: (Full: 12);

                                        Group {
                                            LayoutMode: Left;
                                            
                                            Group { FlexWeight: 1; }
                                            
                                            Label #RaceDetailCooldownWarning {
                                                Text: "You will be locked for the remaining cooldown after swapping.";
                                                Style: (FontSize: 11, TextColor: #ffc300, RenderBold: true);
                                            }
                                        }
                                    
                                        Group { Anchor: (Height: 8); }

                                        Group {
                                            LayoutMode: Left;
               
                                            $C.@TextButton #ViewRacePathsButton {
                                                Text: "VIEW PATHS";
                                                Anchor: (Height: 32, Width: 170);
                                                Style: @CustomStyle;
                                            }

                                            Group { FlexWeight: 1; }

                                            $C.@TextButton #ConfirmRaceButton {
                                                Text: "SWAP";
                                                Anchor: (Height: 32, Width: 170);
                                                Style: @CustomStyle;
                                            }
                                        }
                                    }   
                                }             
                            }
                        }

                        Group { Anchor: (Width: 40); }

                        $C.@DecoratedContainer {
                            Anchor: (Width: 300);

                            #Title {
                                Group {
                                    $C.@Title #RacesInfoPanel { @Text = "INFO"; }
                                }
                            }

                            #Content {
                                LayoutMode: Top;
                                Padding: (Horizontal: 12, Bottom: 12);

                                Group #RaceStatusCard {
                                    LayoutMode: Top;
                                    Background: #0b141f(0.92);
                                    Padding: (Full: 10);

                                    Label #RaceCurrentTitle {
                                        Text: "Current Race";
                                        Style: (FontSize: 12, TextColor: #8aa1bf, RenderBold: true, LetterSpacing: 1);
                                        Anchor: (Height: 12);
                                    }

                                    Group { Anchor: (Height: 8); }

                                    Group {
                                        LayoutMode: Left;
                                        Anchor: (Height: 20);
                                        Label #RaceCurrentBadge {
                                            Text: "Active";
                                            Style: (FontSize: 11, TextColor: #6fe3ff, RenderBold: true);
                                        }
                                        Group { Anchor: (Width: 8); }
                                        Label #CurrentRaceValue {
                                            Text: "--";
                                            Style: (FontSize: 13, TextColor: #ffffff, RenderBold: true);
                                            FlexWeight: 1;
                                        }
                                    }

                                    Group { Anchor: (Height: 6); }

                                    Label #RaceCurrentHint {
                                        Text: "Your active race sets identity and innate bonuses.";
                                        Style: (FontSize: 11, TextColor: #9fb6d3);
                                        Anchor: (Height: 14);
                                    }
                                }

                                Group { Anchor: (Height: 6); }

                                Group #RaceSwapCooldownCard {
                                    LayoutMode: Top;
                                    Background: #0b141f(0.92);
                                    Padding: (Full: 8);

                                    Group {
                                        LayoutMode: Top;

                                        Label #RaceSwapCooldownCardTitle {
                                            Text: "Race Swap Cooldown";
                                            Style: (FontSize: 12, TextColor: #8aa1bf, RenderBold: true, LetterSpacing: 1);
                                        }

                                        Group { FlexWeight: 1; }

                                        Label #RaceSwapCooldownHint {
                                            Text: "Swapping again becomes available once the timer hits zero.";
                                            Style: (FontSize: 11, TextColor: #9fb6d3);
                                        }

                                        Group { Anchor: (Height: 4); }

                                        Label #RaceSwapCooldownValue {
                                            Text: "--";
                                            Style: (FontSize: 20, TextColor: #6fe3ff, RenderBold: true);
                                        }
                                    }
                                }             
                            }
                        }
                    }
                }
            }
        }
    }
}

$C.@BackButton {}
