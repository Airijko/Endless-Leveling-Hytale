$C = "../../Common.ui";

Group {
    LayoutMode: Top;

    Group {
        LayoutMode: Left;
        Background: #0b141f(0.8);
        Padding: (Full: 14);

        Group {
            Anchor: (Width: 4);
            Background: #4fd7f7(0.95);
        }

        Group {
            LayoutMode: Top;
            Padding: (Horizontal: 12);
            FlexWeight: 1;

            Group {
                LayoutMode: Left;

                Label #RaceName {
                    Style: (FontSize: 18, TextColor: #ffffff, RenderBold: true);
                    Text: "Race Name";
                    FlexWeight: 1;
                }

                Label #RaceSelectionStatus {
                    Style: (FontSize: 12, TextColor: #4fd7f7, RenderBold: true);
                    Text: "CURRENT";
                    Anchor: (Height: 18);
                    Visible: false;
                }
            }

            Group { Anchor: (Height: 5); }

            Group {
                LayoutMode: Left;

                $C.@TextButton #ViewRaceButton {
                    Text: "VIEW";
                    Anchor: (Height: 34, Width: 125);
                }

                Group { Anchor: (Width: 8); }

                $C.@TextButton #ChooseRaceButton {
                    Text: "CHOOSE";
                    Anchor: (Height: 34, Width: 125);
                }
            }
        }
    }

    Group { Anchor: (Height: 8); }
}
