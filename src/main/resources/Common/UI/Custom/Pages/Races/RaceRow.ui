$C = "../../Common.ui";

Group {
    LayoutMode: Top;

    Group {
        LayoutMode: Left;
        Background: #0b141f(0.8);
        Padding: (Full: 10);

        Group {
            Anchor: (Width: 4);
            Background: #4fd7f7(0.95);
        }

        Group {
            LayoutMode: Top;
            Padding: (Horizontal: 8);
            FlexWeight: 1;

            Group {
                LayoutMode: Left;

                Label #RaceName {
                    Style: (FontSize: 14, TextColor: #ffffff, RenderBold: true);
                    Text: "Race Name";
                    FlexWeight: 1;
                }

                Label #RaceSelectionStatus {
                    Style: (FontSize: 10, TextColor: #4fd7f7, RenderBold: true);
                    Text: "CURRENT";
                    Anchor: (Height: 14);
                    Visible: false;
                }
            }

            Group { Anchor: (Height: 3); }

            Group {
                LayoutMode: Left;

                $C.@TextButton #ViewRaceButton {
                    Text: "VIEW";
                    Anchor: (Height: 28, Width: 96);
                    Padding: (Horizontal: 10, Vertical: 4);
                }

                Group { Anchor: (Width: 6); }

                $C.@TextButton #ChooseRaceButton {
                    Text: "CHOOSE";
                    Anchor: (Height: 28, Width: 96);
                    Padding: (Horizontal: 10, Vertical: 4);
                }
            }
        }
    }

    Group { Anchor: (Height: 6); }
}
