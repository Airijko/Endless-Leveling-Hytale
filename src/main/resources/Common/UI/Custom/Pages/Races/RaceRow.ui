$C = "../../Common.ui";

Group {
    LayoutMode: Top;

    Group {
        LayoutMode: Left;
        Anchor: (Height: 140);
        Background: #050910(0.88);
        Padding: (Left: 14, Right: 14, Top: 12, Bottom: 12);

        Group {
            Anchor: (Width: 4);
            Background: #4fd7f7(0.95);
        }

        Group {
            FlexWeight: 1;
            LayoutMode: Top;
            Padding: (Left: 12, Right: 12, Bottom: 12);

            Group {
                LayoutMode: Left;
                Anchor: (Height: 22);

                Label #RaceName {
                    Style: (FontSize: 18, TextColor: #ffffff, RenderBold: true);
                    Text: "Race Name";
                    FlexWeight: 1;
                }

                Label #RaceSelectionStatus {
                    Style: (FontSize: 12, TextColor: #4fd7f7, RenderBold: true);
                    Text: "CURRENT";
                    Anchor: (Height: 18);
                    Visible: false;
                }
            }

            Group { Anchor: (Height: 10); }

            Group {
                LayoutMode: Left;
                Anchor: (Height: 34);

                Group {
                    LayoutMode: Top;
                    Anchor: (Width: 150);

                    Label {
                        Text: "Primary Role";
                        Style: (FontSize: 11, TextColor: #8aa1bf, RenderBold: true);
                        Anchor: (Height: 14);
                    }

                    Label #RacePrimaryRoleLabel {
                        Text: "--";
                        Style: (FontSize: 13, TextColor: #ffffff, RenderBold: true);
                        Anchor: (Height: 18);
                    }
                }

                Group { Anchor: (Width: 16); }

                Group {
                    LayoutMode: Top;
                    Anchor: (Width: 150);

                    Label {
                        Text: "Secondary Role";
                        Style: (FontSize: 11, TextColor: #8aa1bf, RenderBold: true);
                        Anchor: (Height: 14);
                    }

                    Label #RaceSecondaryRoleLabel {
                        Text: "--";
                        Style: (FontSize: 13, TextColor: #ffffff, RenderBold: true);
                        Anchor: (Height: 18);
                    }
                }
            }

            Group { FlexWeight: 1; }

            Group {
                LayoutMode: Left;
                Anchor: (Height: 38);

                $C.@TextButton #ViewRaceButton {
                    Text: "VIEW";
                    Anchor: (Height: 34, Width: 125);
                }

                Group { Anchor: (Width: 12); }

                $C.@TextButton #ChooseRaceButton {
                    Text: "CHOOSE";
                    Anchor: (Height: 34, Width: 125);
                }

                Group { FlexWeight: 1; }
            }
        }
    }

    Group { Anchor: (Height: 8); }
}
