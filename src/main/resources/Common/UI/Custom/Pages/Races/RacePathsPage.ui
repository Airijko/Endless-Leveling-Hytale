$C = "../../Common.ui";
$Nav = "../Nav/LeftNavPanel.ui";

$C.@PageOverlay {
    Group {
    LayoutMode: Middle;

        Group {
            LayoutMode: Top;
            Anchor: (Width: 1480);

            Group {
                LayoutMode: Middle;
                Anchor: (Width: 1480);

                Group {
                    LayoutMode: Left;

                    Group { Anchor: (Width: 240); }

                    // Main Content Container
                    $C.@DecoratedContainer {
                        Anchor: (Width: 1000, Height: 700);
                        #Title {
                            Group {
                                Padding: (Horizontal: 6, Vertical: 8);

                                $C.@Title {
                                    @Text = "ENDLESS LEVELING";
                                }
                            }
                        }

                        #Content {
                            LayoutMode: Left;
                            Padding: (Full: 0);

                            $Nav.@LeftNavPanel {}

                            Group #RightPanel {
                                FlexWeight: 1;
                                LayoutMode: Left;
                                Anchor: (Right: 7, Bottom: 7);

                                Group #RacePathMainPanel {
                                    FlexWeight: 1;
                                    LayoutMode: Top;

                                    Label #RacePathsTitleLabel {
                                        Text: "Race Paths";
                                        Style: (FontSize: 26, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center);
                                        Anchor: (Height: 36);
                                    }

                                    Group { Anchor: (Height: 1); Background: #2b3542; }
                                    Group { Anchor: (Height: 14); }

                                    Label #RacePathsSubtitleLabel {
                                        Text: "Progress through tiers from your base race and converge into final forms.";
                                        Style: (FontSize: 13, TextColor: #9fb6d3, HorizontalAlignment: Center);
                                        Anchor: (Height: 20, Bottom: 6);
                                    }

                                    Group #RacePathScrollArea {
                                        FlexWeight: 1;
                                        LayoutMode: LeftScrolling;
                                        ScrollbarStyle: $C.@DefaultScrollbarStyle;

                                        Group #RacePathRows {
                                            LayoutMode: Left;
                                            Padding: (Horizontal: 6, Vertical: 24);
                                            Group { Anchor: (Width: 20); }
                                        }
                                    }

                                    Group #RacePathLegendPanel {
                                        Anchor: (Height: 130, Top: 8);
                                        LayoutMode: Top;
                                        Padding: (Horizontal: 6, Vertical: 10);
                                        Background: #111a28(0.78);

                                        Label {
                                            Text: "STATUS LEGEND";
                                            Style: (FontSize: 12, TextColor: #9fb6d3, RenderBold: true, HorizontalAlignment: Center, LetterSpacing: 1);
                                            Anchor: (Height: 16, Bottom: 6);
                                        }

                                        Group { Anchor: (Height: 1, Bottom: 6); Background: #ffffff(0.08); }

                                        Group {
                                            LayoutMode: Left;
                                            Anchor: (Height: 40, Bottom: 6);

                                            Group {
                                                FlexWeight: 1;
                                                LayoutMode: Top;

                                                Label {
                                                    Text: "Active";
                                                    Style: (FontSize: 12, TextColor: #9cd8ff, RenderBold: true, HorizontalAlignment: Center);
                                                    Anchor: (Height: 16, Bottom: 2);
                                                }
                                                Label {
                                                    Text: "Your current race form.";
                                                    Style: (FontSize: 11, TextColor: #c5d4e8, HorizontalAlignment: Center, Wrap: true);
                                                }
                                            }

                                            Group {
                                                FlexWeight: 1;
                                                LayoutMode: Top;

                                                Label {
                                                    Text: "Unlocked";
                                                    Style: (FontSize: 12, TextColor: #7fa6cf, RenderBold: true, HorizontalAlignment: Center);
                                                    Anchor: (Height: 16, Bottom: 2);
                                                }
                                                Label {
                                                    Text: "You have this form.";
                                                    Style: (FontSize: 11, TextColor: #c5d4e8, HorizontalAlignment: Center, Wrap: true);
                                                }
                                            }

                                            Group {
                                                FlexWeight: 1;
                                                LayoutMode: Top;

                                                Label {
                                                    Text: "Available";
                                                    Style: (FontSize: 12, TextColor: #9adf86, RenderBold: true, HorizontalAlignment: Center);
                                                    Anchor: (Height: 16, Bottom: 2);
                                                }
                                                Label {
                                                    Text: "Requirements met.";
                                                    Style: (FontSize: 11, TextColor: #c5d4e8, HorizontalAlignment: Center, Wrap: true);
                                                }
                                            }

                                            Group {
                                                FlexWeight: 1;
                                                LayoutMode: Top;

                                                Label {
                                                    Text: "Locked";
                                                    Style: (FontSize: 12, TextColor: #e07050, RenderBold: true, HorizontalAlignment: Center);
                                                    Anchor: (Height: 16, Bottom: 2);
                                                }
                                                Label {
                                                    Text: "Requirements not met.";
                                                    Style: (FontSize: 11, TextColor: #c5d4e8, HorizontalAlignment: Center, Wrap: true);
                                                }
                                            }
                                        }

                                        Label {
                                            Text: "Tip: Scroll horizontally to view higher tiers and alternate branches.";
                                            Style: (FontSize: 11, TextColor: #7fa6cf, Wrap: true, HorizontalAlignment: Center);
                                            Anchor: (Height: 28);
                                        }
                                    }
                                }
                            }
                        }
                    }

                    Group { Anchor: (Width: 40); }

                    $C.@DecoratedContainer {
                        Anchor: (Width: 240, Height: 700);

                        #Title {
                            Group {
                                $C.@Title {
                                    @Text = "PATH INFO";
                                }
                            }
                        }

                        #Content {
                            LayoutMode: TopScrolling;
                            ScrollbarStyle: $C.@DefaultScrollbarStyle;

                            Group {
                                LayoutMode: Top;
                                Padding: (Horizontal: 6, Top: 12, Bottom: 8);

                                ItemIcon #PathInfoIcon {
                                    ItemId: "Ingredient_Life_Essence";
                                    Anchor: (Width: 54, Height: 54, Bottom: 8);
                                }

                                Label #PathInfoName {
                                    Text: "Select a path";
                                    Style: (FontSize: 16, TextColor: #dbe7f5, RenderBold: true, HorizontalAlignment: Center, Wrap: true);
                                    Anchor: (Height: 24, Bottom: 5);
                                }

                                $C.@TextButton #ChooseRacePathButton {
                                    Text: "SELECT PATH";
                                    Anchor: (Height: 32, Width: 160);
                                }
                            }

                            Group { Anchor: (Height: 1, Bottom: 8); Background: #ffffff(0.08); }

                            Group {
                                LayoutMode: Top;
                                Padding: (Horizontal: 6, Bottom: 8);

                                Label {
                                    Text: "STATUS";
                                    Style: (FontSize: 12, TextColor: #9fb6d3, RenderBold: true, HorizontalAlignment: Center);
                                    Anchor: (Height: 18, Bottom: 6);
                                }

                                Label #PathInfoStatus {
                                    Text: "Waiting for selection";
                                    Style: (FontSize: 12, TextColor: #9fb6d3, Wrap: true, HorizontalAlignment: Center, RenderBold: true);
                                    Anchor: (Height: 18);
                                }
                            }

                            Group { Anchor: (Height: 1, Bottom: 8); Background: #ffffff(0.08); }

                            Group {
                                LayoutMode: Top;
                                Padding: (Horizontal: 6, Bottom: 8);

                                Label {
                                    Text: "ASCENSION";
                                    Style: (FontSize: 12, TextColor: #9fb6d3, RenderBold: true, HorizontalAlignment: Center);
                                    Anchor: (Height: 18, Bottom: 6);
                                }

                                Label #PathInfoPath {
                                    Text: "Path: -";
                                    Style: (FontSize: 12, TextColor: #c5d4e8, Wrap: true);
                                    Anchor: (Bottom: 4);
                                }

                                Label #PathInfoStage {
                                    Text: "Stage: -";
                                    Style: (FontSize: 12, TextColor: #c5d4e8, Wrap: true);
                                    Anchor: (Bottom: 4);
                                }

                                Label #PathInfoSource {
                                    Text: "Source: -";
                                    Style: (FontSize: 12, TextColor: #c5d4e8, Wrap: true);
                                }
                            }

                            Group { Anchor: (Height: 1, Bottom: 8); Background: #ffffff(0.08); }

                            Group {
                                LayoutMode: Top;
                                Padding: (Horizontal: 6, Bottom: 8);

                                Label {
                                    Text: "ATTRIBUTES";
                                    Style: (FontSize: 12, TextColor: #9fb6d3, RenderBold: true, HorizontalAlignment: Center);
                                    Anchor: (Height: 18, Bottom: 6);
                                }

                                Label #PathInfoAttributes {
                                    Text: "-";
                                    Style: (FontSize: 11, TextColor: #c5d4e8, Wrap: true);
                                }
                            }

                            Group { Anchor: (Height: 1, Bottom: 8); Background: #ffffff(0.08); }

                            Group {
                                LayoutMode: Top;
                                Padding: (Horizontal: 6, Bottom: 8);

                                Label {
                                    Text: "PASSIVES";
                                    Style: (FontSize: 12, TextColor: #9fb6d3, RenderBold: true, HorizontalAlignment: Center);
                                    Anchor: (Height: 18, Bottom: 6);
                                }

                                Label #PathInfoPassives {
                                    Text: "-";
                                    Style: (FontSize: 11, TextColor: #c5d4e8, Wrap: true);
                                }
                            }

                            Group { Anchor: (Height: 1, Bottom: 8); Background: #ffffff(0.08); }

                            Group {
                                LayoutMode: Top;
                                Padding: (Horizontal: 6, Bottom: 12);

                                Label {
                                    Text: "REQUIREMENTS";
                                    Style: (FontSize: 12, TextColor: #9fb6d3, RenderBold: true, HorizontalAlignment: Center);
                                    Anchor: (Height: 18, Bottom: 6);
                                }

                                Label #PathInfoRequirements {
                                    Text: "Hover or select a race path to inspect requirements.";
                                    Style: (FontSize: 11, TextColor: #c5d4e8, Wrap: true);
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}