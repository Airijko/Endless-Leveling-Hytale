$C = "../../Common.ui";
$Nav = "../Nav/LeftNavPanel.ui";

$C.@PageOverlay {
    $C.@DecoratedContainer {
        Anchor: (Width: 1000, Height: 700);
        #Title {
            Group {
                $C.@Title {
                    @Text = "ENDLESS LEVELING";
                }
            }
        }

        #Content {
            LayoutMode: Left;
            Padding: (Full: 0);

            $Nav.@LeftNavPanel {}

            Group #RightPanel {
                FlexWeight: 1;
                LayoutMode: Top;
                Anchor: (Right: 7, Bottom: 7);
                Padding: (Horizontal: 16, Vertical: 16);

                Label #RacePathsTitleLabel {
                    Text: "Race Paths";
                    Style: (FontSize: 26, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center);
                    Anchor: (Height: 36);
                }

                Group { Anchor: (Height: 1); Background: #2b3542; }
                Group { Anchor: (Height: 14); }

                Label #RacePathsSubtitleLabel {
                    Text: "Progress through tiers from your base class and converge into final forms.";
                    Style: (FontSize: 13, TextColor: #9fb6d3, HorizontalAlignment: Center);
                    Anchor: (Height: 20, Bottom: 6);
                }

                Group #RacePathScrollArea {
                    FlexWeight: 1;
                    LayoutMode: LeftScrolling;
                    ScrollbarStyle: $C.@DefaultScrollbarStyle;

                    Group #RacePathRows {
                        LayoutMode: Left;
                        Padding: (Horizontal: 12, Vertical: 24);
                        Group { Anchor: (Width: 20); }
                    }
                }
            }
        }
    }
}
