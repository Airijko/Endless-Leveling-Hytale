$C = "../../Common.ui";
$Nav = "../Nav/LeftNavPanel.ui";

$C.@PageOverlay {
    $C.@DecoratedContainer {
        Anchor: (Width: 1000, Height: 700);
        #Title {
            Group {
                $C.@Title {
                    @Text = "ENDLESS LEVELING";
                }
            }
        }

        #Content {
            LayoutMode: Left;
            Padding: (Full: 0);

            $Nav.@LeftNavPanel {}

            Group #RightPanel {
                FlexWeight: 1;
                LayoutMode: Top;
                Anchor: (Right: 7, Bottom: 7);
                Padding: (Horizontal: 16, Vertical: 16);

                Label #RacePathsTitleLabel {
                    Text: "Race Paths";
                    Style: (FontSize: 26, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center);
                    Anchor: (Height: 36);
                }

                Group { Anchor: (Height: 1); Background: #2b3542; }
                Group { Anchor: (Height: 14); }

                Label #RacePathsSubtitleLabel {
                    Text: "Choose one of two branches, evolve into tier-two forms, then converge into a final form.";
                    Style: (FontSize: 13, TextColor: #9fb6d3, HorizontalAlignment: Center);
                    Anchor: (Height: 20, Bottom: 6);
                }

                Group #RacePathScrollArea {
                    FlexWeight: 1;
                    LayoutMode: TopScrolling;
                    ScrollbarStyle: $C.@DefaultScrollbarStyle;

                    Group #RacePathCanvas {
                        LayoutMode: Top;
                        Padding: (Horizontal: 24, Vertical: 12);

                    // Top node: current/base race.
                    Group #RacePathBaseRow {
                        LayoutMode: Middle;
                        Anchor: (Height: 130);

                        Button #RacePathBaseSlot {
                            Anchor: (Width: 160, Height: 112);
                            Padding: (Full: 10);
                            Background: (Color: #0f1724(0.9));
                            LayoutMode: Top;
                            Style: (
                                Hovered: (
                                    Background: #1a2638(0.95)
                                ),
                                Pressed: (
                                    Background: #23324b(0.95)
                                )
                            );

                            ItemIcon #RacePathBaseIcon {
                                Anchor: (Width: 46, Height: 46, Bottom: 6);
                            }

                            Label #RacePathBaseName {
                                Text: "Base";
                                Style: (FontSize: 13, TextColor: #ffffff, RenderBold: true, Wrap: true, HorizontalAlignment: Center);
                                Anchor: (Height: 30);
                            }
                        }
                    }

                    Group #RacePathTopConnectorRow {
                        LayoutMode: Middle;
                        Anchor: (Height: 26);

                        Label {
                            Text: "/   \\";
                            Style: (FontSize: 19, TextColor: #7fa6cf, HorizontalAlignment: Center, RenderBold: true);
                            Anchor: (Height: 22);
                        }
                    }

                    // Middle nodes: branch options for this race path.
                    Group #RacePathBranchRow {
                        LayoutMode: Left;
                        Anchor: (Height: 130);

                        Group { FlexWeight: 1; }

                        Button #RacePathBranchSlot1 {
                            Anchor: (Width: 158, Height: 112, Right: 56);
                            Padding: (Full: 10);
                            Background: (Color: #131d2c(0.88));
                            LayoutMode: Top;
                            Style: (
                                Hovered: (
                                    Background: #1c2b40(0.95)
                                ),
                                Pressed: (
                                    Background: #263852(0.95)
                                )
                            );

                            ItemIcon #RacePathBranchIcon1 {
                                Anchor: (Width: 40, Height: 40, Bottom: 6);
                            }

                            Label #RacePathBranchName1 {
                                Text: "Branch 1";
                                Style: (FontSize: 12, TextColor: #dbe7f5, RenderBold: true, Wrap: true, HorizontalAlignment: Center);
                                Anchor: (Height: 30);
                            }
                        }

                        Button #RacePathBranchSlot2 {
                            Anchor: (Width: 158, Height: 112);
                            Padding: (Full: 10);
                            Background: (Color: #131d2c(0.88));
                            LayoutMode: Top;
                            Style: (
                                Hovered: (
                                    Background: #1c2b40(0.95)
                                ),
                                Pressed: (
                                    Background: #263852(0.95)
                                )
                            );

                            ItemIcon #RacePathBranchIcon2 {
                                Anchor: (Width: 40, Height: 40, Bottom: 6);
                            }

                            Label #RacePathBranchName2 {
                                Text: "Branch 2";
                                Style: (FontSize: 12, TextColor: #dbe7f5, RenderBold: true, Wrap: true, HorizontalAlignment: Center);
                                Anchor: (Height: 30);
                            }
                        }

                        Group { FlexWeight: 1; }
                    }

                    Group #RacePathBottomConnectorRow {
                        LayoutMode: Middle;
                        Anchor: (Height: 26);

                        Label {
                            Text: "|                 |";
                            Style: (FontSize: 19, TextColor: #7fa6cf, HorizontalAlignment: Center, RenderBold: true);
                            Anchor: (Height: 22);
                        }
                    }

                    // Tier-two counterpart nodes.
                    Group #RacePathTier2Row {
                        LayoutMode: Left;
                        Anchor: (Height: 130);

                        Group { FlexWeight: 1; }

                        Button #RacePathTier2Slot1 {
                            Anchor: (Width: 158, Height: 112, Right: 56);
                            Padding: (Full: 10);
                            Background: (Color: #182233(0.9));
                            LayoutMode: Top;
                            Style: (
                                Hovered: (
                                    Background: #213047(0.95)
                                ),
                                Pressed: (
                                    Background: #2b3d59(0.95)
                                )
                            );

                            ItemIcon #RacePathTier2Icon1 {
                                Anchor: (Width: 40, Height: 40, Bottom: 6);
                            }

                            Label #RacePathTier2Name1 {
                                Text: "Tier 2 - A";
                                Style: (FontSize: 12, TextColor: #e4edf8, RenderBold: true, Wrap: true, HorizontalAlignment: Center);
                                Anchor: (Height: 30);
                            }
                        }

                        Button #RacePathTier2Slot2 {
                            Anchor: (Width: 158, Height: 112);
                            Padding: (Full: 10);
                            Background: (Color: #182233(0.9));
                            LayoutMode: Top;
                            Style: (
                                Hovered: (
                                    Background: #213047(0.95)
                                ),
                                Pressed: (
                                    Background: #2b3d59(0.95)
                                )
                            );

                            ItemIcon #RacePathTier2Icon2 {
                                Anchor: (Width: 40, Height: 40, Bottom: 6);
                            }

                            Label #RacePathTier2Name2 {
                                Text: "Tier 2 - B";
                                Style: (FontSize: 12, TextColor: #e4edf8, RenderBold: true, Wrap: true, HorizontalAlignment: Center);
                                Anchor: (Height: 30);
                            }
                        }

                        Group { FlexWeight: 1; }
                    }

                    Group #RacePathTier2ToFinalConnectorRow {
                        LayoutMode: Middle;
                        Anchor: (Height: 26);

                        Label {
                            Text: "\\   /";
                            Style: (FontSize: 19, TextColor: #7fa6cf, HorizontalAlignment: Center, RenderBold: true);
                            Anchor: (Height: 22);
                        }
                    }

                    // Bottom node: final converged form.
                    Group #RacePathFinalRow {
                        LayoutMode: Middle;
                        Anchor: (Height: 136);

                        Button #RacePathFinalSlot {
                            Anchor: (Width: 178, Height: 118);
                            Padding: (Full: 10);
                            Background: (Color: #1a2231(0.92));
                            LayoutMode: Top;
                            Style: (
                                Hovered: (
                                    Background: #25324a(0.95)
                                ),
                                Pressed: (
                                    Background: #2f3f5c(0.95)
                                )
                            );

                            ItemIcon #RacePathFinalIcon {
                                Anchor: (Width: 48, Height: 48, Bottom: 6);
                            }

                            Label #RacePathFinalName {
                                Text: "Final";
                                Style: (FontSize: 13, TextColor: #ffe59f, RenderBold: true, Wrap: true, HorizontalAlignment: Center);
                                Anchor: (Height: 30);
                            }
                        }
                    }

                        Group { Anchor: (Height: 20); }
                    }
                }
            }
        }
    }
}
