$C = "../../Common.ui";
$Nav = "../Nav/LeftNavPanel.ui";

$C.@PageOverlay {
    Group {
    LayoutMode: Middle;

        Group {
            LayoutMode: Top;
            Anchor: (Width: 1480);
            Padding: (Full: 12);


            Group {
                LayoutMode: Middle;
                Anchor: (Width: 1480);

                Group {
                    LayoutMode: Left;

                    Group { Anchor: (Width: 240); }

                    // Main Content Container
                    $C.@DecoratedContainer {
                        Anchor: (Width: 1000, Height: 700);
                        #Title {
                            Group {
                                $C.@Title {
                                    @Text = "ENDLESS LEVELING";
                                }
                            }
                        }

                        #Content {
                            LayoutMode: Left;
                            Padding: (Full: 0);

                            $Nav.@LeftNavPanel {}

                            Group #RightPanel {
                                FlexWeight: 1;
                                LayoutMode: Left;
                                Anchor: (Right: 7, Bottom: 7);

                                Group #RacePathMainPanel {
                                    FlexWeight: 1;
                                    LayoutMode: Top;

                                    Label #RacePathsTitleLabel {
                                        Text: "Race Paths";
                                        Style: (FontSize: 26, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center);
                                        Anchor: (Height: 36);
                                    }

                                    Group { Anchor: (Height: 1); Background: #2b3542; }
                                    Group { Anchor: (Height: 14); }

                                    Label #RacePathsSubtitleLabel {
                                        Text: "Progress through tiers from your base race and converge into final forms.";
                                        Style: (FontSize: 13, TextColor: #9fb6d3, HorizontalAlignment: Center);
                                        Anchor: (Height: 20, Bottom: 6);
                                    }

                                    Group #RacePathScrollArea {
                                        FlexWeight: 1;
                                        LayoutMode: LeftScrolling;
                                        ScrollbarStyle: $C.@DefaultScrollbarStyle;

                                        Group #RacePathRows {
                                            LayoutMode: Left;
                                            Padding: (Horizontal: 12, Vertical: 24);
                                            Group { Anchor: (Width: 20); }
                                        }
                                    }

                                    Group #RacePathLegendPanel {
                                        Anchor: (Height: 122, Top: 8);
                                        LayoutMode: Top;
                                        Padding: (Horizontal: 12, Vertical: 10);
                                        Background: #111a28(0.78);

                                        Label {
                                            Text: "STATUS LEGEND";
                                            Style: (FontSize: 12, TextColor: #9fb6d3, RenderBold: true, HorizontalAlignment: Center, LetterSpacing: 1);
                                            Anchor: (Height: 16, Bottom: 6);
                                        }

                                        Group { Anchor: (Height: 1, Bottom: 6); Background: #ffffff(0.08); }

                                        Label {
                                            Text: "Active: Your current race form.   Unlocked: You have this form.   Available: Requirements met.   Locked: Requirements not met.";
                                            Style: (FontSize: 12, TextColor: #c5d4e8, Wrap: true, HorizontalAlignment: Center);
                                            Anchor: (Height: 32, Bottom: 6);
                                        }

                                        Label {
                                            Text: "Tip: Scroll horizontally to view higher tiers and alternate branches.";
                                            Style: (FontSize: 11, TextColor: #7fa6cf, Wrap: true, HorizontalAlignment: Center);
                                            Anchor: (Height: 28);
                                        }
                                    }
                                }
                            }
                        }
                    }

                    Group { Anchor: (Width: 40); }

                    $C.@DecoratedContainer {
                        Anchor: (Width: 240, Height: 700);

                        #Title {
                            Group {
                                $C.@Title {
                                    @Text = "PATH INFO";
                                }
                            }
                        }

                        #Content {
                            LayoutMode: Top;
                            Padding: (Horizontal: 12, Vertical: 12);

                            ItemIcon #PathInfoIcon {
                                ItemId: "Ingredient_Life_Essence";
                                Anchor: (Width: 54, Height: 54, Bottom: 8);
                            }

                            Label #PathInfoName {
                                Text: "Select a path";
                                Style: (FontSize: 16, TextColor: #dbe7f5, RenderBold: true, HorizontalAlignment: Center, Wrap: true);
                                Anchor: (Height: 38, Bottom: 4);
                            }

                            Label #PathInfoSubtitle {
                                Text: "Hover or click a node to inspect it.";
                                Style: (FontSize: 11, TextColor: #9fb6d3, HorizontalAlignment: Center, Wrap: true);
                                Anchor: (Height: 24, Bottom: 8);
                            }

                            Group { Anchor: (Height: 1, Bottom: 8); Background: #ffffff(0.08); }

                            Label {
                                Text: "STATUS";
                                Style: (FontSize: 12, TextColor: #9fb6d3, RenderBold: true, HorizontalAlignment: Center);
                                Anchor: (Height: 18, Bottom: 6);
                            }

                            Label #PathInfoStatus {
                                Text: "Waiting for selection";
                                Style: (FontSize: 12, TextColor: #9fb6d3, Wrap: true, HorizontalAlignment: Center, RenderBold: true);
                                Anchor: (Height: 18, Bottom: 8);
                            }

                            Group { Anchor: (Height: 1, Bottom: 8); Background: #ffffff(0.08); }

                            Label {
                                Text: "ASCENSION";
                                Style: (FontSize: 12, TextColor: #9fb6d3, RenderBold: true, HorizontalAlignment: Center);
                                Anchor: (Height: 18, Bottom: 6);
                            }

                            Label #PathInfoPath {
                                Text: "Path: -";
                                Style: (FontSize: 12, TextColor: #c5d4e8, Wrap: true);
                                Anchor: (Bottom: 4);
                            }

                            Label #PathInfoStage {
                                Text: "Stage: -";
                                Style: (FontSize: 12, TextColor: #c5d4e8, Wrap: true);
                                Anchor: (Bottom: 4);
                            }

                            Label #PathInfoSource {
                                Text: "Source: -";
                                Style: (FontSize: 12, TextColor: #c5d4e8, Wrap: true);
                                Anchor: (Bottom: 8);
                            }

                            Group { Anchor: (Height: 1, Bottom: 8); Background: #ffffff(0.08); }

                            Label {
                                Text: "REQUIREMENTS";
                                Style: (FontSize: 12, TextColor: #9fb6d3, RenderBold: true, HorizontalAlignment: Center);
                                Anchor: (Height: 18, Bottom: 6);
                            }

                            Label #PathInfoRequirements {
                                Text: "Hover or select a race path to inspect requirements.";
                                Style: (FontSize: 11, TextColor: #c5d4e8, Wrap: true);
                                Anchor: (Height: 116, Bottom: 6);
                            }
                        }
                    }
                }
            }
        }
    }
}