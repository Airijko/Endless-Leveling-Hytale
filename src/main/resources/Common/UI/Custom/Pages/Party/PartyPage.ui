$C = "../../Common.ui";
$Nav = "../Nav/LeftNavPanel.ui";

@CustomStyle = TextButtonStyle(
    Default: (Background: $C.@DefaultSquareButtonDefaultBackground, LabelStyle: $C.@DefaultButtonLabelStyle),
    Hovered: (Background: $C.@DefaultSquareButtonHoveredBackground, LabelStyle: $C.@DefaultButtonLabelStyle),
    Pressed: (Background: $C.@DefaultSquareButtonPressedBackground, LabelStyle: $C.@DefaultButtonLabelStyle),
    Disabled: (Background: $C.@DefaultSquareButtonDisabledBackground, LabelStyle: $C.@DefaultButtonDisabledLabelStyle),
    Sounds: $C.@ButtonSounds,
);

@ButtonClusterWidth = 180;

$C.@PageOverlay {
    $C.@Container {
        Anchor: (Width: 800, Height: 700);
        #Title {
            Group {
                $C.@Title {
                    @Text = "ENDLESS LEVELING";
                }
            }
        }

        #Content {
            LayoutMode: Left;
            Padding: (Full: 0);

            // ================= LEFT PANEL =================
            $Nav.@LeftNavPanel {}
            
            // ================= RIGHT PANEL =================
            Group #RightPanel {
                FlexWeight: 1;
                LayoutMode: Top;
                Anchor: (Right: 7, Bottom: 7);

                // -------- Title --------
                Label #PartyTitleLabel {
                    Text: "Party";
                    Anchor: (Height: 48);
                    Style: (FontSize: 22, TextColor: #ffffff, RenderBold: true);
                    Padding: (Horizontal: 16, Top: 8);
                }

                Group {
                    Anchor: (Height: 1);
                    Background: #2b3542;
                }

                Group { Anchor: (Height: 10); }

                // -------- CONTENT --------
                Group #Main {
                    LayoutMode: Top;
                    FlexWeight: 1;
                    Padding: (Full: 16);

                    Label #PartyStatus {
                        Style: $C.@DefaultLabelStyle;
                        Text: "You are not in a party.";
                        Anchor: (Height: 40);
                    }

                    Group { Anchor: (Height: 10); }

                    Group #PartyButtons {
                        LayoutMode: Left;
                        Anchor: (Height: 40);

                        $C.@TextButton #CreatePartyButton {
                            Text: "CREATE";
                            Anchor: (Height: 28, Width: 150);
                            Padding: (Left: 16, Right: 16, Top: 4, Bottom: 4);
                            Style: @CustomStyle;
                        }

                        Group { Anchor: (Width: 8); }

                        $C.@TextButton #LeavePartyButton {
                            Text: "LEAVE";
                            Anchor: (Height: 28, Width: 140);
                            Padding: (Left: 16, Right: 16, Top: 4, Bottom: 4);
                            Style: @CustomStyle;
                        }

                        Group { Anchor: (Width: 8); }

                        $C.@CancelTextButton #DisbandPartyButton {
                            Text: "DISBAND";
                            Anchor: (Height: 28, Width: 120);
                            Padding: (Left: 16, Right: 16, Top: 4, Bottom: 4);
                        }
                    }

                    Group { Anchor: (Height: 16); }

                    // -------- MEMBER SECTION --------
                    Label {
                        Text: "Party Members";
                        Style: (FontSize: 18, TextColor: #ffffff, RenderBold: true);
                        Anchor: (Height: 28);
                    }

                    Group { Anchor: (Height: 6); }

                    Group #MemberSection {
                        LayoutMode: Top;
                        FlexWeight: 1;

                        // Scrollable list of party members. Rows are added dynamically.
                        Group #MemberRows {
                            Anchor: (Top: 2);
                            FlexWeight: 1;
                            LayoutMode: TopScrolling;
                            Padding: (Left: 0);
                            ScrollbarStyle: $C.@DefaultScrollbarStyle;

                            Group #MemberCards {
                                LayoutMode: Top;
                            }
                        }
                    }
                }

                // -------- FOOTER --------
                Group #Footer {
                    Anchor: (Height: 40);
                    LayoutMode: Left;
                    Padding: (Full: 16);
                    Background: #000000(0.12);

                    Label {
                        Style: $C.@DefaultLabelStyle;
                        Text: "XP from kills is shared evenly with your party.";
                    }
                }
            }
        }
    }
}

$C.@BackButton {}
