$C = "../../Common.ui";
$Nav = "../Nav/LeftNavPanel.ui";

// Searchable augment browser inspired by the Advanced-Item-Info grid pattern.

$C.@PageOverlay {
    Group {
        LayoutMode: Middle;

        Group {
            LayoutMode: Left;
            Anchor: (Width: 1680, Height: 700);

            Group {
                LayoutMode: Top;
                Anchor: (Width: 1680, Height: 700);

                Group {
                    LayoutMode: Middle;
                    Anchor: (Width: 1680);

                    Group {
                        LayoutMode: Left;

                        $C.@DecoratedContainer {
                            Anchor: (Width: 300, Height: 700);

                            #Title {
                                Group {
                                    $C.@Title #AugmentActionInfo { @Text = "ENDLESS LEVELING"; }
                                }
                            }

                            #Content {
                                LayoutMode: Top;
                                Padding: (Full: 12);

                                $C.@TextButton #OpenAugmentsChooseButton {
                                    Text: "CHOOSE AUGMENTS";
                                    Anchor: (Width: 210, Height: 34);
                                    Padding: (Horizontal: 12);
                                }

                                Label #AugmentsChooseAvailabilityLabel {
                                    Text: "No augments available to choose.";
                                    Style: (FontSize: 14, TextColor: #ff9f9f, RenderBold: true, Wrap: true, VerticalAlignment: Center);
                                    Anchor: (Height: 34);
                                    Padding: (Horizontal: 12);
                                }

                                Group { Anchor: (Height: 10); }

                                Label {
                                    Text: "Augments are powerful passive enhancements that permanently strengthen your character. Earn them by reaching level milestones and through prestige.";
                                    Style: (FontSize: 12, TextColor: #7a9abf, Wrap: true);
                                    Anchor: (Bottom: 10);
                                    Padding: (Horizontal: 12);
                                }

                                Group {
                                    Anchor: (Height: 1, Bottom: 10);
                                    Background: #ffffff(0.08);
                                }

                                Label {
                                    Text: "YOUR COLLECTION";
                                    Style: (FontSize: 11, TextColor: #9fb6d3, RenderBold: true, HorizontalAlignment: Center);
                                    Anchor: (Height: 16, Bottom: 8);
                                    Padding: (Horizontal: 12);
                                }

                                Label #AugmentStatTotal {
                                    Text: "Total: 0 / 0";
                                    Style: (FontSize: 13, TextColor: #c5d4e8);
                                    Anchor: (Height: 20, Bottom: 4);
                                    Padding: (Horizontal: 12);
                                }

                                Label #AugmentStatMythic {
                                    Text: "Mythic: 0 / 0";
                                    Style: (FontSize: 13, TextColor: #b084e0);
                                    Anchor: (Height: 20, Bottom: 4);
                                    Padding: (Horizontal: 12);
                                }

                                Label #AugmentStatElite {
                                    Text: "Elite: 0 / 0";
                                    Style: (FontSize: 13, TextColor: #7ec8f5);
                                    Anchor: (Height: 20, Bottom: 4);
                                    Padding: (Horizontal: 12);
                                }

                                Label #AugmentStatCommon {
                                    Text: "Common: 0 / 0";
                                    Style: (FontSize: 13, TextColor: #e6c168);
                                    Anchor: (Height: 20, Bottom: 10);
                                    Padding: (Horizontal: 12);
                                }

                                Group {
                                    Anchor: (Height: 1, Bottom: 10);
                                    Background: #ffffff(0.08);
                                }

                                Label {
                                    Text: "REROLLS USED";
                                    Style: (FontSize: 11, TextColor: #9fb6d3, RenderBold: true, HorizontalAlignment: Center);
                                    Anchor: (Height: 16, Bottom: 8);
                                    Padding: (Horizontal: 12);
                                }

                                Label #AugmentRerollMythic {
                                    Text: "Mythic: 0";
                                    Style: (FontSize: 13, TextColor: #b084e0);
                                    Anchor: (Height: 20, Bottom: 4);
                                    Padding: (Horizontal: 12);
                                }

                                Label #AugmentRerollElite {
                                    Text: "Elite: 0";
                                    Style: (FontSize: 13, TextColor: #7ec8f5);
                                    Anchor: (Height: 20, Bottom: 4);
                                    Padding: (Horizontal: 12);
                                }

                                Label #AugmentRerollCommon {
                                    Text: "Common: 0";
                                    Style: (FontSize: 13, TextColor: #e6c168);
                                    Anchor: (Height: 20, Bottom: 10);
                                    Padding: (Horizontal: 12);
                                }

                                Group { FlexWeight: 1; }

                                Label #AugmentsInfoText {
                                    Text: "Hover over an augment to preview it.";
                                    Style: (FontSize: 12, TextColor: #5a7a9a, Wrap: true, HorizontalAlignment: Center);
                                    Anchor: (Bottom: 4);
                                    Padding: (Horizontal: 12);
                                }
                            }
                        }

                        Group { Anchor: (Width: 40); }

                        $C.@DecoratedContainer {
                            Anchor: (Width: 1000, Height: 700);

                            #Title {
                                Group {
                                    LayoutMode: Left;

                                    $C.@Title {
                                        @Text = "AUGMENTS";
                                    }

                                    Group { FlexWeight: 1; }

                                    CompactTextField #SearchInput {
                                        Anchor: (Width: 280, Height: 32, Right: 12);
                                        ExpandedWidth: 280;
                                        CollapsedWidth: 280;
                                        PlaceholderText: "Search augments...";
                                        Padding: (Horizontal: 10);
                                        Style: (FontSize: 14);
                                    }
                                }
                            }

                            #Content {
                                LayoutMode: Left;
                                Padding: (Full: 0);

                                $Nav.@LeftNavPanel {}

                                Group #CommandInfo {
                                    FlexWeight: 1;
                                    LayoutMode: TopScrolling;
                                    Padding: (Left: 10, Right: 10, Top: 10, Bottom: 10);
                                    ScrollbarStyle: $C.@DefaultScrollbarStyle;

                                    Label #AugmentsResultLabel {
                                        Text: "Results: 0";
                                        Style: (FontSize: 14, TextColor: #9fb6d3, RenderBold: true);
                                        Anchor: (Height: 24);
                                    }

                                    Group { Anchor: (Height: 1); }

                                    // UNLOCKED SECTION
                                    Group #UnlockedSection {
                                        Anchor: (Bottom: 10);
                                        LayoutMode: Top;
                                        Visible: false;

                                        Label #UnlockedHeader {
                                            Text: "UNLOCKED";
                                            Style: (FontSize: 16, TextColor: #ffd700, RenderBold: true);
                                            Anchor: (Height: 28);
                                        }

                                        Group #UnlockedCards {
                                            LayoutMode: Top;
                                        }
                                    }

                                    // MYTHIC SECTION
                                    Group #MythicSection {
                                        Anchor: (Bottom: 10);
                                        LayoutMode: Top;
                                        Visible: false;

                                        Label #MythicHeader {
                                            Text: "MYTHIC";
                                            Style: (FontSize: 16, TextColor: #b084e0, RenderBold: true);
                                            Anchor: (Height: 28);
                                        }

                                        Group #MythicCards {
                                            LayoutMode: Top;
                                        }
                                    }

                                    // ELITE SECTION
                                    Group #EliteSection {
                                        Anchor: (Bottom: 10);
                                        LayoutMode: Top;
                                        Visible: false;

                                        Label #EliteHeader {
                                            Text: "ELITE";
                                            Style: (FontSize: 16, TextColor: #7ec8f5, RenderBold: true);
                                            Anchor: (Height: 28);
                                        }

                                        Group #EliteCards {
                                            LayoutMode: Top;
                                        }
                                    }

                                    // COMMON SECTION
                                    Group #CommonSection {
                                        Anchor: (Bottom: 10);
                                        LayoutMode: Top;
                                        Visible: false;

                                        Label #CommonHeader {
                                            Text: "COMMON";
                                            Style: (FontSize: 16, TextColor: #e6c168, RenderBold: true);
                                            Anchor: (Height: 28);
                                        }

                                        Group #CommonCards {
                                            LayoutMode: Top;
                                        }
                                    }
                                }
                            }
                        }

                        Group { Anchor: (Width: 40); }

                        $C.@DecoratedContainer {
                            Anchor: (Width: 300, Height: 700);

                            #Title {
                                Group {
                                    $C.@Title #AugmentInfoPanel { @Text = "AUGMENT INFO"; }
                                }
                            }

                            #Content {
                                LayoutMode: Top;
                                Padding: (Full: 12);

                                // Icon + name row
                                Group #AugmentInfoHeader {
                                    LayoutMode: Top;
                                    Anchor: (Bottom: 10);

                                    Group {
                                        LayoutMode: Middle;

                                        ItemIcon #AugmentInfoIcon {
                                            Anchor: (Width: 72, Height: 72, Bottom: 8);
                                            Visible: false;
                                        }
                                    }

                                    Label #AugmentInfoName {
                                        Text: "Select an augment";
                                        Style: (FontSize: 16, TextColor: #e6edf5, RenderBold: true, Wrap: true, HorizontalAlignment: Center);
                                        Anchor: (Bottom: 4);
                                    }

                                    Label #AugmentInfoTier {
                                        Text: "";
                                        Style: (FontSize: 12, TextColor: #9fb6d3, RenderBold: true, HorizontalAlignment: Center);
                                        Anchor: (Height: 18, Bottom: 4);
                                        Visible: false;
                                    }
                                }

                                // Divider
                                Group #AugmentInfoDivider {
                                    Anchor: (Height: 1, Bottom: 10);
                                    Background: #ffffff(0.08);
                                    Visible: false;
                                }

                                // Description
                                Label #AugmentInfoDescription {
                                    Text: "";
                                    Style: (FontSize: 13, TextColor: #c5d4e8, Wrap: true);
                                    Anchor: (Bottom: 10);
                                    Padding: (Horizontal: 12);
                                    Visible: false;
                                }

                                // Second divider
                                Group #AugmentInfoDivider2 {
                                    Anchor: (Height: 1, Bottom: 10);
                                    Background: #ffffff(0.08);
                                    Padding: (Horizontal: 12);
                                    Visible: false;
                                }

                                // Values
                                Label #AugmentInfoValues {
                                    Text: "";
                                    Style: (FontSize: 12, TextColor: #9fb6d3, Wrap: true);
                                    Padding: (Horizontal: 12);
                                    Visible: false;
                                    
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}