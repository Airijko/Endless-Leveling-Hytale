$C = "../../Common.ui";

// Single augment tile used by the searchable grid.

Button {
    Anchor: (Width: 136, Bottom: 10, Right: 10);
    Padding: (Full: 12);
    Background: (Color: #050b16(0.85));
    LayoutMode: Top;
    Style: (
        Hovered: (
            Background: #1a2d47(0.9)
        ),
        Pressed: (
            Background: #142338(0.9)
        )
    );
    TextTooltipStyle: $C.@DefaultTextTooltipStyle;

    ItemIcon #ItemIcon {
        Anchor: (Width: 67, Height: 67, Bottom: 5);
        Visible: true;
    }

    Label #ItemName {
        Style: (
            FontSize: 14,
            RenderBold: true,
            TextColor: #ffffff,
            Wrap: true,
            HorizontalAlignment: Center
        );
        Anchor: (Bottom: 5);
    }
}
