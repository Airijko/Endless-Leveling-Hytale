$C = "../../Common.ui";

Group {
    LayoutMode: Top;

    Group {
        LayoutMode: Left;
        Anchor: (Height: 95);
        Background: #040405(0.85);
        Padding: (Left: 12, Right: 12, Top: 10, Bottom: 10);

        Group {
            Anchor: (Width: 4);
            Background: #4fd7f7(0.9);
        }

        Group {
            FlexWeight: 1;
            LayoutMode: Top;
            Padding: (Horizontal: 10);

            Group {
                LayoutMode: Left;
                Anchor: (Height: 18);

                Label #SlotLabel {
                    Style: (FontSize: 12, TextColor: #8aa1bf, RenderBold: true);
                    Text: "Slot 1";
                    Anchor: (Height: 16);
                }

                Group { Anchor: (Width: 8); }

                Label #StatusBadge {
                    Anchor: (Height: 18);
                    Style: (FontSize: 12, TextColor: #4fd7f7, RenderBold: true);
                    Text: "";
                }
            }

            Label #ProfileName {
                Style: (FontSize: 20, TextColor: #ffffff, RenderBold: true);
                Text: "Profile";
                Anchor: (Height: 30);
            }

            Group {
                LayoutMode: Left;
                Anchor: (Height: 26);

                Group {
                    LayoutMode: Top;
                    Anchor: (Width: 90);

                    Label {
                        Style: (FontSize: 11, TextColor: #6e7f98, RenderBold: true);
                        Text: "LEVEL";
                        Anchor: (Height: 10);
                    }

                    Label #LevelValue {
                        Style: (FontSize: 14, TextColor: #ffffff);
                        Text: "Level 1";
                        Anchor: (Height: 16);
                    }
                }

                Group { Anchor: (Width: 16); }

                Group {
                    LayoutMode: Top;
                    Anchor: (Width: 120);

                    Label {
                        Style: (FontSize: 11, TextColor: #6e7f98, RenderBold: true);
                        Text: "XP";
                        Anchor: (Height: 10);
                    }

                    Label #XpValue {
                        Style: (FontSize: 14, TextColor: #ffffff);
                        Text: "0 XP";
                        Anchor: (Height: 16);
                    }
                }

                Group { Anchor: (Width: 16); }
            }
        }

        Group {
            LayoutMode: Top;
            Anchor: (Width: 140);
            Background: #0f1d2d(0.65);

            Group { Anchor: (Height: 5); }

            Group #ActionButtons {
                LayoutMode: Top;

                $C.@TextButton #SelectButton {
                    Text: "SELECT";
                    Anchor: (Height: 30, Width: 130);
                }

                Group { Anchor: (Height: 6); }

                $C.@CancelTextButton #DeleteButton {
                    Text: "DELETE";
                    Anchor: (Height: 30, Width: 130);
                }
            }

            Group #ConfirmButtons {
                LayoutMode: Top;
                Visible: false;

                Label #ConfirmDeleteLabel {
                    Text: "Confirm delete?";
                    Style: (FontSize: 11, TextColor: #ff9b73, RenderBold: true);
                    Anchor: (Height: 16);
                }

                Group { Anchor: (Height: 4); }

                $C.@CancelTextButton #ConfirmDeleteButton {
                    Text: "CONFIRM";
                    Anchor: (Height: 28, Width: 130);
                }

                Group { Anchor: (Height: 4); }

                $C.@TextButton #CancelDeleteButton {
                    Text: "CANCEL";
                    Anchor: (Height: 28, Width: 130);
                }
            }
        }
    }

    Group { Anchor: (Height: 8); }
}
