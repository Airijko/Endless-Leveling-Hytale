Group {
    LayoutMode: Left;
    Anchor: (Height: 22);
    Background: #0f1d2d(0.65);
    Padding: (Left: 10, Right: 10, Top: 3, Bottom: 3);

    Label #PassiveName {
        Style: (FontSize: 12, TextColor: #9fb6d3);
        Text: "Passive";
        Anchor: (Height: 16);
    }

    Group { FlexWeight: 1; }

    Label #PassiveValue {
        Style: (FontSize: 12, TextColor: #4fd7f7, RenderBold: true);
        Text: "+0";
        Anchor: (Height: 16);
    }

    Group { Anchor: (Width: 8); }

    Label #PassiveLevel {
        Style: (FontSize: 12, TextColor: #8aa1bf);
        Text: "Lv 0";
        Anchor: (Height: 16);
    }
}
