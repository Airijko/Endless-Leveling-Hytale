$C = "../../Common.ui";
$Nav = "../Nav/LeftNavPanel.ui";

@CustomStyle = TextButtonStyle(
    Default: (Background: $C.@DefaultSquareButtonDefaultBackground, LabelStyle: $C.@DefaultButtonLabelStyle),
    Hovered: (Background: $C.@DefaultSquareButtonHoveredBackground, LabelStyle: $C.@DefaultButtonLabelStyle),
    Pressed: (Background: $C.@DefaultSquareButtonPressedBackground, LabelStyle: $C.@DefaultButtonLabelStyle),
    Disabled: (Background: $C.@DefaultSquareButtonDisabledBackground, LabelStyle: $C.@DefaultButtonDisabledLabelStyle),
    Sounds: $C.@ButtonSounds,
);

$C.@PageOverlay {
    Group {
        LayoutMode: Middle;

        Group {
            LayoutMode: Left;
            Anchor: (Width: 1680, Height: 700);

            Group {
                LayoutMode: Top;
                Anchor: (Width: 1680, Height: 700);

                Group {
                    LayoutMode: Middle;
                    Anchor: (Width: 1680);

                    Group {
                        LayoutMode: Left;

                        $C.@DecoratedContainer {
                            Anchor: (Width: 300, Height: 700);

                            #Title {
                                Group {
                                    $C.@Title #ClassesListPanel { @Text = "CLASSES"; }
                                }
                            }

                            #Content {
                                LayoutMode: Top;
                                Padding: (Horizontal: 12, Bottom: 12);

                                Group #ClassListColumn {
                                    FlexWeight: 1;
                                    LayoutMode: Top;

                                    Group #ClassListHeader {
                                        LayoutMode: Left;
                                        Anchor: (Height: 32);
                                        Padding: (Vertical: 4);

                                        Label #ClassListTitle {
                                            Text: "Available Classes";
                                            Style: (FontSize: 16, TextColor: #ffffff, RenderBold: true, VerticalAlignment: Center);
                                        }

                                        Group { FlexWeight: 1; }

                                        Label #ClassCountLabel {
                                            Text: "0 classes";
                                            Style: (FontSize: 12, TextColor: #9fb6d3, VerticalAlignment: Center);
                                            Anchor: (Height: 18);
                                        }
                                    }

                                    Group { Anchor: (Height: 10); }

                                    Group #ClassListScroll {
                                        FlexWeight: 1;
                                        LayoutMode: TopScrolling;
                                        ScrollbarStyle: $C.@DefaultScrollbarStyle;

                                        Group #ClassRows {
                                            LayoutMode: Top;
                                        }
                                    }
                                }
                            }
                        }

                        Group { Anchor: (Width: 40); }

                        $C.@DecoratedContainer {
                            Anchor: (Width: 1000, Height: 700);
                            #Title {
                                Group {
                                    $C.@Title {
                                        @Text = "ENDLESS LEVELING";
                                    }
                                }
                            }

                            #Content {
                                LayoutMode: Left;
                                Padding: (Full: 0);

                                $Nav.@LeftNavPanel {}

                                Group #LeftContent {
                                    FlexWeight: 1;
                                    LayoutMode: Top;
                                    Anchor: (Right: 7, Bottom: 7);

                                    Group #ClassContent {
                                        LayoutMode: Left;
                                        FlexWeight: 1;
                                        Padding: (Full: 16);

                                        Group #ClassDetailPanel {
                                            LayoutMode: Top;
                                            Anchor: (Width: 430);
                                            Background: #050910(0.85);
                                            Padding: (Left: 18, Right: 18, Top: 18, Bottom: 18);

                                            Label #ClassesTitleLabel {
                                                Text: "Class Codex";
                                                Style: (FontSize: 20, TextColor: #ffffff, RenderBold: true);
                                                Anchor: (Height: 24);
                                            }

                                            Label #SelectedClassLabel {
                                                Text: "Select a Class";
                                                Style: (FontSize: 20, TextColor: #ffffff, RenderBold: true);
                                                Anchor: (Height: 24);
                                            }

                                            Label #SelectedClassSubtitle {
                                                Text: "Choose a class on the left to preview its bonuses.";
                                                Style: (FontSize: 13, TextColor: #8aa1bf);
                                                Anchor: (Height: 18);
                                            }

                                            Group { Anchor: (Height: 8); }

                                            Label #ClassRoleValue {
                                                Text: "Role: --";
                                                Style: (FontSize: 12, TextColor: #9fb6d3, RenderBold: true);
                                                Anchor: (Height: 16);
                                            }

                                            Group {
                                                LayoutMode: Left;
                                                Anchor: (Height: 20);

                                                Label #ClassSorceryLabel {
                                                    Text: "Sorcery Bonus";
                                                    Style: (FontSize: 12, TextColor: #d7baff, RenderBold: true);
                                                }

                                                Group { Anchor: (Width: 8); }

                                                Label #ClassSorceryValue {
                                                    Text: "--";
                                                    Style: (FontSize: 13, TextColor: #e8d5ff, RenderBold: true);
                                                    FlexWeight: 1;
                                                }
                                            }

                                            Group { Anchor: (Height: 8); }
                                            Group { Anchor: (Height: 1); Background: #ffffff(0.08); }
                                            Group { Anchor: (Height: 8); }

                                            Group #ClassDetailScrollArea {
                                                FlexWeight: 1;
                                                LayoutMode: TopScrolling;
                                                ScrollbarStyle: $C.@DefaultScrollbarStyle;

                                                Group #ClassDetailScrollContent {
                                                    LayoutMode: Top;

                                                    Label #ClassLoreTitle {
                                                        Text: "Lore Preview";
                                                        Style: (FontSize: 14, TextColor: #ffffff, RenderBold: true);
                                                        Anchor: (Height: 20);
                                                    }

                                                    Label #ClassLoreText {
                                                        Text: "Dive into the fantasy and goals of this class.";
                                                        Style: (FontSize: 12, TextColor: #9fb6d3, Wrap: true);
                                                        Anchor: (Height: 48);
                                                        FlexWeight: 1;
                                                    }

                                                    Group { Anchor: (Height: 16); }

                                                    Label #ClassWeaponsTitle {
                                                        Text: "Weapon Affinities";
                                                        Style: (FontSize: 14, TextColor: #ffffff, RenderBold: true);
                                                        Anchor: (Height: 20);
                                                    }

                                                    Label #ClassWeaponSummary {
                                                        Text: "This class does not define weapon bonuses.";
                                                        Style: (FontSize: 12, TextColor: #9fb6d3, RenderBold: true);
                                                        Anchor: (Height: 18);
                                                    }

                                                    Group #ClassWeaponEntries {
                                                        LayoutMode: Top;
                                                    }

                                                    Group { Anchor: (Height: 16); }

                                                    Label #ClassInnateTitle {
                                                        Text: "Innate Attribute Gains";
                                                        Style: (FontSize: 14, TextColor: #ffffff, RenderBold: true);
                                                        Anchor: (Height: 20);
                                                    }

                                                    Label #ClassInnateSummary {
                                                        Text: "Inspect a class to preview innate attribute bonuses.";
                                                        Style: (FontSize: 12, TextColor: #9fb6d3, RenderBold: true);
                                                        Anchor: (Height: 18);
                                                    }

                                                    Group #ClassInnateEntries {
                                                        LayoutMode: Top;
                                                    }

                                                    Group { Anchor: (Height: 16); }

                                                    Label #ClassPassivesTitle {
                                                        Text: "Passives";
                                                        Style: (FontSize: 14, TextColor: #ffffff, RenderBold: true);
                                                        Anchor: (Height: 20);
                                                    }

                                                    Label #ClassPassiveSummary {
                                                        Text: "Inspect a class to preview its passive bonuses.";
                                                        Style: (FontSize: 12, TextColor: #9fb6d3, RenderBold: true);
                                                        Anchor: (Height: 18);
                                                    }

                                                    Group #ClassPassiveEntries {
                                                        LayoutMode: Top;
                                                    }
                                                }
                                            }
                                        }

                                        Group { Anchor: (Width: 16); }

                                        Group #RightContent {
                                            LayoutMode: Top;
                                            FlexWeight: 1;
                                            Background: #050910(0.85);
                                            Padding: (Left: 16, Right: 16, Top: 16, Bottom: 16);

                                            Label #ClassEvolutionTitle {
                                                Text: "Class Paths";
                                                Style: (FontSize: 16, TextColor: #ffffff, RenderBold: true);
                                                Anchor: (Height: 22);
                                            }

                                            Label #ClassEvolutionSummary {
                                                Text: "Select a class to inspect ascension branches.";
                                                Style: (FontSize: 12, TextColor: #9fb6d3, RenderBold: true, Wrap: true);
                                                Anchor: (Height: 48);
                                            }

                                            Group { Anchor: (Height: 10); }

                                            Group #ClassEvolutionScrollArea {
                                                FlexWeight: 1;
                                                LayoutMode: TopScrolling;
                                                ScrollbarStyle: $C.@DefaultScrollbarStyle;

                                                Group #ClassEvolutionEntries {
                                                    LayoutMode: Top;
                                                }
                                            }
                                        }
                                    }

                                    Group #ClassDetailActions {
                                        LayoutMode: Top;
                                        Padding: (Full: 12);

                                        Label #ClassDetailStatus {
                                            Text: "Secondary classes grant half value. Changes apply instantly.";
                                            Style: (FontSize: 11, TextColor: #ffc300, RenderBold: true, Wrap: true);
                                            Anchor: (Height: 30);
                                        }

                                        Group { Anchor: (Height: 8); }

                                        Group {
                                            LayoutMode: Left;

                                            $C.@TextButton #ViewClassPathsButton {
                                                Text: "VIEW PATHS";
                                                Anchor: (Height: 32, Width: 170);
                                                Style: @CustomStyle;
                                            }

                                            Group { FlexWeight: 1; }

                                            $C.@TextButton #ConfirmPrimaryButton {
                                                Text: "SET PRIMARY";
                                                FlexWeight: 1;
                                                Anchor: (Height: 32);
                                                Style: @CustomStyle;
                                            }

                                            Group { Anchor: (Width: 8); }

                                            $C.@TextButton #ConfirmSecondaryButton {
                                                Text: "SET SECONDARY";
                                                FlexWeight: 1;
                                                Anchor: (Height: 32);
                                                Style: @CustomStyle;
                                            }
                                        }
                                    }
                                }
                            }
                        }

                        Group { Anchor: (Width: 40); }

                        $C.@DecoratedContainer {
                            Anchor: (Width: 300);

                            #Title {
                                Group {
                                    $C.@Title #ClassesInfoPanel { @Text = "INFO"; }
                                }
                            }

                            #Content {
                                LayoutMode: Top;
                                Padding: (Horizontal: 12, Bottom: 12);

                                Group #ClassStatusCard {
                                    LayoutMode: Top;
                                    Background: #0b141f(0.92);
                                    Padding: (Full: 10);

                                    Label #ClassAssignmentsTitle {
                                        Text: "Class Assignments";
                                        Style: (FontSize: 12, TextColor: #8aa1bf, RenderBold: true, LetterSpacing: 1);
                                        Anchor: (Height: 12);
                                    }

                                    Group { Anchor: (Height: 8); }

                                    Group {
                                        LayoutMode: Left;
                                        Anchor: (Height: 20);
                                        Label #ClassPrimaryStatusLabel {
                                            Text: "Primary";
                                            Style: (FontSize: 11, TextColor: #6fe3ff, RenderBold: true);
                                        }
                                        Group { Anchor: (Width: 8); }
                                        Label #CurrentPrimaryValue {
                                            Text: "--";
                                            Style: (FontSize: 13, TextColor: #ffffff, RenderBold: true);
                                            FlexWeight: 1;
                                        }
                                    }

                                    Group {
                                        LayoutMode: Left;
                                        Anchor: (Height: 20);
                                        Label #ClassSecondaryStatusLabel {
                                            Text: "Secondary";
                                            Style: (FontSize: 11, TextColor: #d4b5ff, RenderBold: true);
                                        }
                                        Group { Anchor: (Width: 8); }
                                        Label #CurrentSecondaryValue {
                                            Text: "None";
                                            Style: (FontSize: 13, TextColor: #ffffff, RenderBold: true);
                                            FlexWeight: 1;
                                        }
                                    }

                                    Group { Anchor: (Height: 6); }

                                    Label #ClassSecondaryShareHint {
                                        Text: "Secondary classes share 50% of bonuses.";
                                        Style: (FontSize: 11, TextColor: #9fb6d3);
                                        Anchor: (Height: 14);
                                    }
                                }

                                Group { Anchor: (Height: 6); }

                                Group #ClassSwapCooldownCard {
                                    LayoutMode: Top;
                                    Background: #0b141f(0.92);
                                    Padding: (Full: 8);

                                    Group {
                                        LayoutMode: Top;

                                        Label #ClassSwapCooldownCardTitle {
                                            Text: "Class Swap Cooldown";
                                            Style: (FontSize: 12, TextColor: #8aa1bf, RenderBold: true, LetterSpacing: 1);
                                        }

                                        Group { FlexWeight: 1; }

                                        Label #ClassSwapCooldownHint {
                                            Text: "Class swaps share a cooldown per slot.";
                                            Style: (FontSize: 11, TextColor: #9fb6d3, Wrap: true);
                                        }

                                        Group { Anchor: (Height: 8); }

                                        Group {
                                            LayoutMode: Left;
                                            Anchor: (Height: 18);

                                            Label #ClassPrimaryCooldownLabel {
                                                Text: "Primary";
                                                Style: (FontSize: 11, TextColor: #6fe3ff, RenderBold: true, VerticalAlignment: Center);
                                            }

                                            Group { FlexWeight: 1; }

                                            Label #ClassPrimaryCooldownValue {
                                                Text: "--";
                                                Style: (FontSize: 11, TextColor: #ffffff, RenderBold: true, VerticalAlignment: Center);
                                            }
                                        }

                                        Group { Anchor: (Height: 4); }

                                        Group {
                                            LayoutMode: Left;
                                            Anchor: (Height: 18);

                                            Label #ClassSecondaryCooldownLabel {
                                                Text: "Secondary";
                                                Style: (FontSize: 11, TextColor: #d4b5ff, RenderBold: true, VerticalAlignment: Center);
                                            }

                                            Group { FlexWeight: 1; }

                                            Label #ClassSecondaryCooldownValue {
                                                Text: "--";
                                                Style: (FontSize: 11, TextColor: #ffffff, RenderBold: true, VerticalAlignment: Center);
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}

$C.@BackButton {}
