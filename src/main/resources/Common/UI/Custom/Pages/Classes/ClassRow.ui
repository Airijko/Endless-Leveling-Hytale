$C = "../../Common.ui";

@CustomLabelStyle = LabelStyle(
  FontSize: 12,
  TextColor: #bfcdd5,
  RenderBold: true,
  RenderUppercase: true,
  HorizontalAlignment: Center,
  VerticalAlignment: Center
);

@CustomStyle = TextButtonStyle(
  Default: (Background: $C.@DefaultSquareButtonDefaultBackground, LabelStyle: @CustomLabelStyle),
  Hovered: (Background: $C.@DefaultSquareButtonHoveredBackground, LabelStyle: @CustomLabelStyle),
  Pressed: (Background: $C.@DefaultSquareButtonPressedBackground, LabelStyle: @CustomLabelStyle),
  Disabled: (Background: $C.@DefaultSquareButtonDisabledBackground, LabelStyle: @CustomLabelStyle),
  Sounds: $C.@ButtonSounds,
);

Group {
    LayoutMode: Top;

    Group {
        LayoutMode: Left;
        Anchor: (Height: 110);
        Background: #050910(0.88);
        Padding: (Horizontal: 14, Vertical: 12);

        Group {
            Anchor: (Width: 4);
            Background: #4fd7f7(0.95);
        }

        Group {
            FlexWeight: 1;
            LayoutMode: Top;
            Padding: (Left: 12, Right: 12, Bottom: 12);

            Group {
                LayoutMode: Left;
                Anchor: (Height: 22);

                Label #ClassName {
                    Style: (FontSize: 18, TextColor: #ffffff, RenderBold: true);
                    Text: "Class Name";
                    FlexWeight: 1;
                }

                Label #ClassSelectionStatus {
                    Style: (FontSize: 12, TextColor: #4fd7f7, RenderBold: true);
                    Text: "PRIMARY";
                    Anchor: (Height: 18);
                    Visible: false;
                }
            }

            Group { Anchor: (Height: 10); }
            Group { FlexWeight: 1; }

            Group {
                LayoutMode: Left;
                Anchor: (Height: 32);

                $C.@TextButton #ViewClassButton {
                    Text: "VIEW";
                    Anchor: (Width: 60, Height: 26);
                    Padding: (Horizontal: 5, Vertical: 2);
                    Style: @CustomStyle;
                }

                Group { Anchor: (Width: 8); }

                $C.@TextButton #SetPrimaryButton {
                    Text: "PRIMARY";
                    Anchor: (Width: 90, Height: 26);
                    Padding: (Horizontal: 5, Vertical: 2);
                    Style: @CustomStyle;
                }

                Group { Anchor: (Width: 8); }

                $C.@TextButton #SetSecondaryButton {
                    Text: "SECONDARY";
                    Anchor: (Width: 95, Height: 26);
                    Padding: (Horizontal: 5, Vertical: 2);
                    Style: @CustomStyle;
                }

                Group { FlexWeight: 1; }
            }
        }
    }

    Group { Anchor: (Height: 8); }
}
