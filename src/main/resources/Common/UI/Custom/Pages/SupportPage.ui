$C = "../Common.ui";
$Nav = "Nav/LeftNavPanel.ui";

$C.@PageOverlay {
    $C.@DecoratedContainer {
        Anchor: (Width: 1000, Height: 700);
        #Title {
            Group {
                $C.@Title #SupportTitle {
                    @Text = "ENDLESS LEVELING";
                }
            }
        }

        #Content {
            LayoutMode: Left;
            Padding: (Full: 0);

            // ================= LEFT PANEL =================
            $Nav.@LeftNavPanel {}

            // ================= RIGHT PANEL =================
            Group #RightPanel {
                FlexWeight: 1;
                LayoutMode: Top;
                Anchor: (Right: 7, Bottom: 7);

                // -------- Title --------
                Group #Header {
                    LayoutMode: Left;
                    Anchor: (Height: 60);
                    Padding: (Horizontal: 16, Vertical: 10);

                    Label #SupportTitleLabel {
                        Text: "Support";
                        Anchor: (Height: 60);
                        Style: (FontSize: 22, TextColor: #ffffff, RenderBold: true, VerticalAlignment: Center);
                    }
                }

                Group {
                    Anchor: (Height: 1);
                    Background: #2b3542;
                }

                // -------- CONTENT --------
                Group #Main {
                    LayoutMode: TopScrolling;
                    ScrollbarStyle: $C.@DefaultScrollbarStyle;
                    FlexWeight: 1;
                    Padding: (Full: 24);

                    // -------- Credit Card --------
                    Group #CreditCard {
                        LayoutMode: Top;
                        Background: #0b141f(0.92);
                        Padding: (Full: 20);

                        Label #SupportModName {
                            Text: "Endless Leveling";
                            Anchor: (Height: 36);
                            Style: (FontSize: 26, TextColor: #ffffff, RenderBold: true, VerticalAlignment: Center);
                        }

                        Group { Anchor: (Height: 6); }

                        Label #SupportDeveloperLabel {
                            Text: "Developer: Airijko";
                            Anchor: (Height: 22);
                            Style: (FontSize: 14, TextColor: #4fd7f7, VerticalAlignment: Center);
                        }
                    }

                    Group { Anchor: (Height: 20); }

                    // -------- Notice Card --------
                    Group #NoticeCard {
                        LayoutMode: Top;
                        Background: #0f1e2e(0.88);
                        Padding: (Full: 20);

                        Label #SupportNotice1 {
                            Text: "Some redistributed versions alter the UI or remove the Endless Leveling name and credit.";
                            Style: (TextColor: #c0cee5, FontSize: 14);
                        }

                        Group { Anchor: (Height: 10); }

                        Label #SupportNotice2 {
                            Text: "These versions are not official.";
                            Style: (TextColor: #ff9966, FontSize: 14, RenderBold: true);
                        }

                        Group { Anchor: (Height: 10); }

                        Label #SupportNotice3 {
                            Text: "If you enjoy the mod, please support the original project and developer.";
                            Style: (TextColor: #c0cee5, FontSize: 14);
                        }
                    }
                }

                Group #DiscordCard {
                    LayoutMode: Left;
                    Background: #0b141f(0.84);
                    Padding: (Full: 16);

                    Group {
                        LayoutMode: Top;
                        FlexWeight: 1;

                        Label #SupportDiscordTitle {
                            Text: "Need help?";
                            Anchor: (Height: 24);
                            Style: (FontSize: 15, TextColor: #ffffff, RenderBold: true, VerticalAlignment: Center);
                        }

                        Group { Anchor: (Height: 4); }

                        Label #SupportDiscordDescription {
                            Text: "For support, issues, and help, join our Discord community.";
                            Style: (TextColor: #c0cee5, FontSize: 13);
                        }
                    }

                    Group { Anchor: (Width: 12); }

                    $C.@TextButton #SupportDiscordButton {
                        Anchor: (Width: 170, Height: 34);
                        Padding: (Horizontal: 8, Vertical: 4);
                        Text: "Join Discord";
                    }
                }
            }
        }
    }
}

$C.@BackButton {}
