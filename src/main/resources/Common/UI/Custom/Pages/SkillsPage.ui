$C = "../Common.ui";
$Nav = "Nav/LeftNavPanel.ui";

@CustomStyle = TextButtonStyle(
    Default: (Background: $C.@DefaultSquareButtonDefaultBackground, LabelStyle: $C.@DefaultButtonLabelStyle),
    Hovered: (Background: $C.@DefaultSquareButtonHoveredBackground, LabelStyle: $C.@DefaultButtonLabelStyle),
    Pressed: (Background: $C.@DefaultSquareButtonPressedBackground, LabelStyle: $C.@DefaultButtonLabelStyle),
    Disabled: (Background: $C.@DefaultSquareButtonDisabledBackground, LabelStyle: $C.@DefaultButtonDisabledLabelStyle),
    Sounds: $C.@ButtonSounds,
);

@ButtonClusterWidth = 180;

$C.@PageOverlay {
    $C.@DecoratedContainer {
        Anchor: (Width: 1000, Height: 700);
        #Title {
            Group {
                $C.@Title {
                    @Text = "ENDLESS LEVELING";
                }
            }
        }

        #Content {
            LayoutMode: Left;
            Padding: (Full: 0);

            // ================= LEFT PANEL =================
            $Nav.@LeftNavPanel {}
            
            // ================= RIGHT PANEL =================
            Group #RightPanel {
                FlexWeight: 1;
                LayoutMode: Top;
                Anchor: (Right: 7, Bottom: 7);

                // -------- Title --------
                Group #Header {
                    LayoutMode: Left;
                    Anchor: (Height: 60);
                    Padding: (Horizontal: 16, Vertical: 10);

                    Label {
                        Text: "Skill Attributes";
                        Anchor: (Height: 60);
                        Style: (FontSize: 22, TextColor: #ffffff, RenderBold: true, VerticalAlignment: Center);
                    }

                    Group { FlexWeight: 1; }

                    Group #SkillsIntro {
                        LayoutMode: Top;
                        Background: #111b2d;
                        Padding: (Full: 12);
                        Label {
                            Style: (TextColor: #aaccff, FontSize: 14);
                            Text: "Allocate points to shape your combat identity.";
                        }
                    }
                }

                Group { Anchor: (Height: 1); Background: #2b3542; }

                // -------- SKILLS --------
                Group #Main {
                    FlexWeight: 1;
                    LayoutMode: TopScrolling;
                    ScrollbarStyle: $C.@DefaultScrollbarStyle;
                    Padding: (Full: 16);

                    Group #Skills {
                        LayoutMode: Left;

                        Group #SkillsColumnLeft {
                            FlexWeight: 1;
                            LayoutMode: Top;

                            // ---------------- LIFE FORCE ----------------
                            Group #LifeForce {
                                LayoutMode: Top;
                                Background: #0b141f(0.8);
                                Padding: (Full: 12);

                                Group {
                                    LayoutMode: Left;

                                    Group {
                                        Anchor: (Width: 56, Height: 56);
                                        Background: #050b16(0.85);
                                        LayoutMode: Middle;
                                        Padding: (Full: 8);
                                        ItemIcon #LifeForceIcon {
                                            Anchor: (Width: 36, Height: 36);
                                            Visible: false;
                                        }
                                    }

                                    Group { Anchor: (Width: 12); }

                                    Group {
                                        LayoutMode: Top;
                                        FlexWeight: 1;
                                        Group {
                                            LayoutMode: Left;
                                            FlexWeight: 1;

                                            Label #LifeForceLabel { Style: (TextColor: #f4f9ff, FontSize: 16, RenderBold: true); FlexWeight: 1; }
                                            
                                            Group { FlexWeight: 1; }
                                            
                                            Label {
                                                Text: "Lv.";
                                                Style: (TextColor: #94b2ff, FontSize: 13);
                                                Anchor: (Width: 24);
                                            }
                                            
                                            Label #LifeForceLevel { Style: (TextColor: #94b2ff, FontSize: 13); Anchor: (Width: 70); }
                                        }

                                        Group {
                                            LayoutMode: Left;
                                            FlexWeight: 1;
                                 
                                            Label #LifeForceValue { Style: (TextColor: #6fe3ff, FontSize: 13, RenderBold: true); Anchor: (Width: 120); }

                                            Group { FlexWeight: 1; }
                                        }
                                    }
                                }

                                Group { Anchor: (Height: 4); }

                                Label #LifeForceDescription {
                                    Style: (TextColor: #c0cee5, FontSize: 12);
                                    Text: "Boosts total health.";
                                }

                                Group { Anchor: (Height: 6); }

                                Group {
                                    LayoutMode: Left;
                                    Group { FlexWeight: 1; }
                                    Group #LifeForceButtons {
                                        Anchor: (Width: @ButtonClusterWidth);
                                        LayoutMode: Left;
                                        Group { FlexWeight: 1; }

                                        $C.@TextButton #LifeForceMinus1 {
                                            Anchor: (Height: 28, Width: 46);
                                            Padding: (Horizontal: 12, Vertical: 4);
                                            Text: "-1";
                                            Style: @CancelTextButtonStyle;
                                        }

                                        Group { Anchor: (Width: 4); }

                                        $C.@TextButton #LifeForcePlus1 {
                                            Anchor: (Height: 28, Width: 46);
                                            Padding: (Horizontal: 12, Vertical: 4);
                                            Text: "+1";
                                            Style: @CustomStyle;
                                        }

                                        Group { Anchor: (Width: 4); }

                                        $C.@TextButton #LifeForcePlus5 {
                                            Anchor: (Height: 28, Width: 46);
                                            Padding: (Horizontal: 12, Vertical: 4);
                                            Text: "+5";
                                            Style: @CustomStyle;
                                        }
                                    }
                                }
                            }

                            Group { Anchor: (Height: 12); }

                            // ---------------- STRENGTH ----------------
                            Group #Strength {
                                LayoutMode: Top;
                                Background: #0b141f(0.8);
                                Padding: (Full: 12);

                                Group {
                                    LayoutMode: Left;
                                    Group {
                                        Anchor: (Width: 56, Height: 56);
                                        Background: #050b16(0.85);
                                        LayoutMode: Middle;
                                        Padding: (Full: 8);
                                        ItemIcon #StrengthIcon {
                                            Anchor: (Width: 36, Height: 36);
                                            Visible: false;
                                        }
                                    }

                                    Group { Anchor: (Width: 12); }

                                    Group {
                                        LayoutMode: Top;
                                        FlexWeight: 1;

                                        Group {
                                            LayoutMode: Left;
                                            FlexWeight: 1;

                                            Label #StrengthLabel { Style: (TextColor: #ffe8d7, FontSize: 16, RenderBold: true); FlexWeight: 1; }

                                            Group { FlexWeight: 1; }

                                            Label {
                                                Text: "Lv.";
                                                Style: (TextColor: #ffc49c, FontSize: 13);
                                                Anchor: (Width: 24);
                                            }

                                            Label #StrengthLevel { Style: (TextColor: #ffc49c, FontSize: 13); Anchor: (Width: 70); }
                                        }

                                        Group {
                                            LayoutMode: Left;
                                            FlexWeight: 1;

                                            Label #StrengthValue { Style: (TextColor: #ffd2ac, FontSize: 13, RenderBold: true); Anchor: (Width: 120); }

                                            Group { FlexWeight: 1; }
                                        }
                                    }
                                }

                                Group { Anchor: (Height: 4); }

                                Label #StrengthDescription {
                                    Style: (TextColor: #ffe0c5, FontSize: 12);
                                    Text: "Adds damage multipliers to every hit.";
                                }

                                Group { Anchor: (Height: 6); }

                                Group {
                                    LayoutMode: Left;
                                    Group { FlexWeight: 1; }
                                    Group #StrengthButtons {
                                        Anchor: (Width: @ButtonClusterWidth);
                                        LayoutMode: Left;
                                        Group { FlexWeight: 1; }

                                        $C.@TextButton #StrengthMinus1 {
                                            Anchor: (Height: 28, Width: 46);
                                            Padding: (Horizontal: 12, Vertical: 4);
                                            Text: "-1";
                                            Style: @CancelTextButtonStyle;
                                        }

                                        Group { Anchor: (Width: 4); }

                                        $C.@TextButton #StrengthPlus1 {
                                            Anchor: (Height: 28, Width: 46);
                                            Padding: (Horizontal: 12, Vertical: 4);
                                            Text: "+1";
                                            Style: @CustomStyle;
                                        }

                                        Group { Anchor: (Width: 4); }

                                        $C.@TextButton #StrengthPlus5 {
                                            Anchor: (Height: 28, Width: 46);
                                            Padding: (Horizontal: 12, Vertical: 4);
                                            Text: "+5";
                                            Style: @CustomStyle;
                                        }
                                    }
                                }
                            }

                            Group { Anchor: (Height: 12); }

                            // ---------------- DEFENSE ----------------
                            Group #Defense {
                                LayoutMode: Top;
                                Background: #0b141f(0.8);
                                Padding: (Full: 12);

                                Group {
                                    LayoutMode: Left;
                                    Group {
                                        Anchor: (Width: 56, Height: 56);
                                        Background: #050b16(0.85);
                                        LayoutMode: Middle;
                                        Padding: (Full: 8);
                                        ItemIcon #DefenseIcon {
                                            Anchor: (Width: 36, Height: 36);
                                            Visible: false;
                                        }
                                    }

                                    Group { Anchor: (Width: 12); }

                                    Group {
                                        LayoutMode: Top;
                                        FlexWeight: 1;

                                        Group {
                                            LayoutMode: Left;
                                            FlexWeight: 1;

                                            Label #DefenseLabel { Style: (TextColor: #ddfff3, FontSize: 16, RenderBold: true); FlexWeight: 1; }

                                            Group { FlexWeight: 1; }

                                            Label {
                                                Text: "Lv.";
                                                Style: (TextColor: #94ffe3, FontSize: 13);
                                                Anchor: (Width: 24);
                                            }

                                            Label #DefenseLevel { Style: (TextColor: #94ffe3, FontSize: 13); Anchor: (Width: 70); }
                                        }

                                        Group {
                                            LayoutMode: Left;
                                            FlexWeight: 1;

                                            Label #DefenseValue { Style: (TextColor: #68f7c5, FontSize: 13, RenderBold: true); Anchor: (Width: 120); }

                                            Group { FlexWeight: 1; }
                                        }
                                    }
                                }

                                Group { Anchor: (Height: 4); }

                                Label #DefenseDescription {
                                    Style: (TextColor: #c7ede4, FontSize: 12);
                                    Text: "Shrugs off more incoming damage.";
                                }

                                Group { Anchor: (Height: 6); }

                                Group {
                                    LayoutMode: Left;
                                    Group { FlexWeight: 1; }
                                    Group #DefenseButtons {
                                        Anchor: (Width: @ButtonClusterWidth);
                                        LayoutMode: Left;
                                        Group { FlexWeight: 1; }

                                        $C.@TextButton #DefenseMinus1 {
                                            Anchor: (Height: 28, Width: 46);
                                            Padding: (Horizontal: 12, Vertical: 4);
                                            Text: "-1";
                                            Style: @CancelTextButtonStyle;
                                        }

                                        Group { Anchor: (Width: 4); }

                                        $C.@TextButton #DefensePlus1 {
                                            Anchor: (Height: 28, Width: 46);
                                            Padding: (Horizontal: 12, Vertical: 4);
                                            Text: "+1";
                                            Style: @CustomStyle;
                                        }

                                        Group { Anchor: (Width: 4); }

                                        $C.@TextButton #DefensePlus5 {
                                            Anchor: (Height: 28, Width: 46);
                                            Padding: (Horizontal: 12, Vertical: 4);
                                            Text: "+5";
                                            Style: @CustomStyle;
                                        }
                                    }
                                }
                            }

                            Group { Anchor: (Height: 12); }

                            // ---------------- HASTE ----------------
                            Group #Haste {
                                LayoutMode: Top;
                                Background: #0b141f(0.8);
                                Padding: (Full: 12);

                                Group {
                                    LayoutMode: Left;
                                    Group {
                                        Anchor: (Width: 56, Height: 56);
                                        Background: #050b16(0.85);
                                        LayoutMode: Middle;
                                        Padding: (Full: 8);
                                        ItemIcon #HasteIcon {
                                            Anchor: (Width: 36, Height: 36);
                                            Visible: false;
                                        }
                                    }

                                    Group { Anchor: (Width: 12); }

                                    Group {
                                        LayoutMode: Top;
                                        FlexWeight: 1;

                                        Group {
                                            LayoutMode: Left;
                                            FlexWeight: 1;

                                            Label #HasteLabel { Style: (TextColor: #f7e2ff, FontSize: 16, RenderBold: true); FlexWeight: 1; }

                                            Group { FlexWeight: 1; }

                                            Label {
                                                Text: "Lv.";
                                                Style: (TextColor: #e0b8ff, FontSize: 13);
                                                Anchor: (Width: 24);
                                            }

                                            Label #HasteLevel { Style: (TextColor: #e0b8ff, FontSize: 13); Anchor: (Width: 70); }
                                        }

                                        Group {
                                            LayoutMode: Left;
                                            FlexWeight: 1;

                                            Label #HasteValue { Style: (TextColor: #d598ff, FontSize: 13, RenderBold: true); Anchor: (Width: 120); }

                                            Group { FlexWeight: 1; }
                                        }
                                    }
                                }

                                Group { Anchor: (Height: 4); }

                                Label #HasteDescription {
                                    Style: (TextColor: #dccdf3, FontSize: 12);
                                    Text: "Cranks up movement and attack speed.";
                                }

                                Group { Anchor: (Height: 6); }

                                Group {
                                    LayoutMode: Left;
                                    Group { FlexWeight: 1; }
                                    Group #HasteButtons {
                                        Anchor: (Width: @ButtonClusterWidth);
                                        LayoutMode: Left;
                                        Group { FlexWeight: 1; }

                                        $C.@TextButton #HasteMinus1 {
                                            Anchor: (Height: 28, Width: 46);
                                            Padding: (Horizontal: 12, Vertical: 4);
                                            Text: "-1";
                                            Style: @CancelTextButtonStyle;
                                        }

                                        Group { Anchor: (Width: 4); }

                                        $C.@TextButton #HastePlus1 {
                                            Anchor: (Height: 28, Width: 46);
                                            Padding: (Horizontal: 12, Vertical: 4);
                                            Text: "+1";
                                            Style: @CustomStyle;
                                        }

                                        Group { Anchor: (Width: 4); }

                                        $C.@TextButton #HastePlus5 {
                                            Anchor: (Height: 28, Width: 46);
                                            Padding: (Horizontal: 12, Vertical: 4);
                                            Text: "+5";
                                            Style: @CustomStyle;
                                        }
                                    }
                                }
                            }
                        }

                        Group { Anchor: (Width: 24); }

                        Group #SkillsColumnRight {
                            FlexWeight: 1;
                            LayoutMode: Top;

                            // ---------------- PRECISION ----------------
                            Group #Precision {
                                LayoutMode: Top;
                                Background: #0b141f(0.8);
                                Padding: (Full: 12);

                                Group {
                                    LayoutMode: Left;
                                    Group {
                                        Anchor: (Width: 56, Height: 56);
                                        Background: #050b16(0.85);
                                        LayoutMode: Middle;
                                        Padding: (Full: 8);
                                        ItemIcon #PrecisionIcon {
                                            Anchor: (Width: 36, Height: 36);
                                            Visible: false;
                                        }
                                    }

                                    Group { Anchor: (Width: 12); }

                                    Group {
                                        LayoutMode: Top;
                                        FlexWeight: 1;

                                        Group {
                                            LayoutMode: Left;
                                            FlexWeight: 1;

                                            Label #PrecisionLabel { Style: (TextColor: #dff6ff, FontSize: 16, RenderBold: true); FlexWeight: 1; }

                                            Group { FlexWeight: 1; }

                                            Label {
                                                Text: "Lv.";
                                                Style: (TextColor: #87dfff, FontSize: 13);
                                                Anchor: (Width: 24);
                                            }

                                            Label #PrecisionLevel { Style: (TextColor: #87dfff, FontSize: 13); Anchor: (Width: 70); }
                                        }

                                        Group {
                                            LayoutMode: Left;
                                            FlexWeight: 1;

                                            Label #PrecisionValue { Style: (TextColor: #6edcff, FontSize: 13, RenderBold: true); Anchor: (Width: 120); }

                                            Group { FlexWeight: 1; }
                                        }
                                    }
                                }

                                Group { Anchor: (Height: 4); }

                                Label #PrecisionDescription {
                                    Style: (TextColor: #c3dfee, FontSize: 12);
                                    Text: "Raises crit chance for all attacks.";
                                }

                                Group { Anchor: (Height: 6); }

                                Group {
                                    LayoutMode: Left;
                                    Group { FlexWeight: 1; }
                                    Group #PrecisionButtons {
                                        Anchor: (Width: @ButtonClusterWidth);
                                        LayoutMode: Left;
                                        Group { FlexWeight: 1; }

                                        $C.@TextButton #PrecisionMinus1 {
                                            Anchor: (Height: 28, Width: 46);
                                            Padding: (Horizontal: 12, Vertical: 4);
                                            Text: "-1";
                                            Style: @CancelTextButtonStyle;
                                        }

                                        Group { Anchor: (Width: 4); }

                                        $C.@TextButton #PrecisionPlus1 {
                                            Anchor: (Height: 28, Width: 46);
                                            Padding: (Horizontal: 12, Vertical: 4);
                                            Text: "+1";
                                            Style: @CustomStyle;
                                        }

                                        Group { Anchor: (Width: 4); }

                                        $C.@TextButton #PrecisionPlus5 {
                                            Anchor: (Height: 28, Width: 46);
                                            Padding: (Horizontal: 12, Vertical: 4);
                                            Text: "+5";
                                            Style: @CustomStyle;
                                        }
                                    }
                                }
                            }

                            Group { Anchor: (Height: 12); }

                            // ---------------- FEROCITY ----------------
                            Group #Ferocity {
                                LayoutMode: Top;
                                Background: #0b141f(0.8);
                                Padding: (Full: 12);

                                Group {
                                    LayoutMode: Left;
                                    Group {
                                        Anchor: (Width: 56, Height: 56);
                                        Background: #050b16(0.85);
                                        LayoutMode: Middle;
                                        Padding: (Full: 8);
                                        ItemIcon #FerocityIcon {
                                            Anchor: (Width: 36, Height: 36);
                                            Visible: false;
                                        }
                                    }

                                    Group { Anchor: (Width: 12); }

                                    Group {
                                        LayoutMode: Top;
                                        FlexWeight: 1;

                                        Group {
                                            LayoutMode: Left;
                                            FlexWeight: 1;

                                            Label #FerocityLabel { Style: (TextColor: #ffdbe9, FontSize: 16, RenderBold: true); FlexWeight: 1; }

                                            Group { FlexWeight: 1; }

                                            Label {
                                                Text: "Lv.";
                                                Style: (TextColor: #ff9ac0, FontSize: 13);
                                                Anchor: (Width: 24);
                                            }

                                            Label #FerocityLevel { Style: (TextColor: #ff9ac0, FontSize: 13); Anchor: (Width: 70); }
                                        }

                                        Group {
                                            LayoutMode: Left;
                                            FlexWeight: 1;

                                            Label #FerocityValue { Style: (TextColor: #ffb0cd, FontSize: 13, RenderBold: true); Anchor: (Width: 120); }

                                            Group { FlexWeight: 1; }
                                        }
                                    }
                                }

                                Group { Anchor: (Height: 4); }

                                Label #FerocityDescription {
                                    Style: (TextColor: #fac6da, FontSize: 12);
                                    Text: "Stacks bonus damage onto crits.";
                                }

                                Group { Anchor: (Height: 6); }

                                Group {
                                    LayoutMode: Left;
                                    Group { FlexWeight: 1; }
                                    Group #FerocityButtons {
                                        Anchor: (Width: @ButtonClusterWidth);
                                        LayoutMode: Left;
                                        Group { FlexWeight: 1; }

                                        $C.@TextButton #FerocityMinus1 {
                                            Anchor: (Height: 28, Width: 46);
                                            Padding: (Horizontal: 12, Vertical: 4);
                                            Text: "-1";
                                            Style: @CancelTextButtonStyle;
                                        }

                                        Group { Anchor: (Width: 4); }

                                        $C.@TextButton #FerocityPlus1 {
                                            Anchor: (Height: 28, Width: 46);
                                            Padding: (Horizontal: 12, Vertical: 4);
                                            Text: "+1";
                                            Style: @CustomStyle;
                                        }

                                        Group { Anchor: (Width: 4); }

                                        $C.@TextButton #FerocityPlus5 {
                                            Anchor: (Height: 28, Width: 46);
                                            Padding: (Horizontal: 12, Vertical: 4);
                                            Text: "+5";
                                            Style: @CustomStyle;
                                        }
                                    }
                                }
                            }

                            Group { Anchor: (Height: 12); }

                            // ---------------- STAMINA ----------------
                            Group #Stamina {
                                LayoutMode: Top;
                                Background: #0b141f(0.8);
                                Padding: (Full: 12);

                                Group {
                                    LayoutMode: Left;
                                    Group {
                                        Anchor: (Width: 56, Height: 56);
                                        Background: #050b16(0.85);
                                        LayoutMode: Middle;
                                        Padding: (Full: 8);
                                        ItemIcon #StaminaIcon {
                                            Anchor: (Width: 36, Height: 36);
                                            Visible: false;
                                        }
                                    }

                                    Group { Anchor: (Width: 12); }

                                    Group {
                                        LayoutMode: Top;
                                        FlexWeight: 1;

                                        Group {
                                            LayoutMode: Left;
                                            FlexWeight: 1;

                                            Label #StaminaLabel { Style: (TextColor: #ecffd0, FontSize: 16, RenderBold: true); FlexWeight: 1; }

                                            Group { FlexWeight: 1; }

                                            Label {
                                                Text: "Lv.";
                                                Style: (TextColor: #d2ff8f, FontSize: 13);
                                                Anchor: (Width: 24);
                                            }

                                            Label #StaminaLevel { Style: (TextColor: #d2ff8f, FontSize: 13); Anchor: (Width: 70); }
                                        }

                                        Group {
                                            LayoutMode: Left;
                                            FlexWeight: 1;

                                            Label #StaminaValue { Style: (TextColor: #b7ff6a, FontSize: 13, RenderBold: true); Anchor: (Width: 120); }

                                            Group { FlexWeight: 1; }
                                        }
                                    }
                                }

                                Group { Anchor: (Height: 4); }

                                Label #StaminaDescription {
                                    Style: (TextColor: #d8f2b0, FontSize: 12);
                                    Text: "Extends stamina for dodges and bursts.";
                                }

                                Group { Anchor: (Height: 6); }

                                Group {
                                    LayoutMode: Left;
                                    Group { FlexWeight: 1; }
                                    Group #StaminaButtons {
                                        Anchor: (Width: @ButtonClusterWidth);
                                        LayoutMode: Left;
                                        Group { FlexWeight: 1; }

                                        $C.@TextButton #StaminaMinus1 {
                                            Anchor: (Height: 28, Width: 46);
                                            Padding: (Horizontal: 12, Vertical: 4);
                                            Text: "-1";
                                            Style: @CancelTextButtonStyle;
                                        }

                                        Group { Anchor: (Width: 4); }

                                        $C.@TextButton #StaminaPlus1 {
                                            Anchor: (Height: 28, Width: 46);
                                            Padding: (Horizontal: 12, Vertical: 4);
                                            Text: "+1";
                                            Style: @CustomStyle;
                                        }

                                        Group { Anchor: (Width: 4); }

                                        $C.@TextButton #StaminaPlus5 {
                                            Anchor: (Height: 28, Width: 46);
                                            Padding: (Horizontal: 12, Vertical: 4);
                                            Text: "+5";
                                            Style: @CustomStyle;
                                        }
                                    }
                                }
                            }

                            Group { Anchor: (Height: 12); }

                            // ---------------- INTELLIGENCE ----------------
                            Group #Intelligence {
                                LayoutMode: Top;
                                Background: #0b141f(0.8);
                                Padding: (Full: 12);

                                Group {
                                    LayoutMode: Left;
                                    Group {
                                        Anchor: (Width: 56, Height: 56);
                                        Background: #050b16(0.85);
                                        LayoutMode: Middle;
                                        Padding: (Full: 8);
                                        ItemIcon #IntelligenceIcon {
                                            Anchor: (Width: 36, Height: 36);
                                            Visible: false;
                                        }
                                    }

                                    Group { Anchor: (Width: 12); }

                                    Group {
                                        LayoutMode: Top;
                                        FlexWeight: 1;

                                        Group {
                                            LayoutMode: Left;
                                            FlexWeight: 1;

                                            Label #IntelligenceLabel { Style: (TextColor: #e1f4ff, FontSize: 16, RenderBold: true); FlexWeight: 1; }

                                            Group { FlexWeight: 1; }

                                            Label {
                                                Text: "Lv.";
                                                Style: (TextColor: #7edbff, FontSize: 13);
                                                Anchor: (Width: 24);
                                            }

                                            Label #IntelligenceLevel { Style: (TextColor: #7edbff, FontSize: 13); Anchor: (Width: 70); }
                                        }

                                        Group {
                                            LayoutMode: Left;
                                            FlexWeight: 1;

                                            Label #IntelligenceValue { Style: (TextColor: #60d2ff, FontSize: 13, RenderBold: true); Anchor: (Width: 120); }

                                            Group { FlexWeight: 1; }
                                        }
                                    }
                                }

                                Group { Anchor: (Height: 4); }

                                Label #IntelligenceDescription {
                                    Style: (TextColor: #c1dff5, FontSize: 12);
                                    Text: "Feeds mana for abilities and spells.";
                                }

                                Group { Anchor: (Height: 6); }

                                Group {
                                    LayoutMode: Left;
                                    Group { FlexWeight: 1; }
                                    Group #IntelligenceButtons {
                                        Anchor: (Width: @ButtonClusterWidth);
                                        LayoutMode: Left;
                                        Group { FlexWeight: 1; }

                                        $C.@TextButton #IntelligenceMinus1 {
                                            Anchor: (Height: 28, Width: 46);
                                            Padding: (Horizontal: 12, Vertical: 4);
                                            Text: "-1";
                                            Style: @CancelTextButtonStyle;
                                        }

                                        Group { Anchor: (Width: 4); }

                                        $C.@TextButton #IntelligencePlus1 {
                                            Anchor: (Height: 28, Width: 46);
                                            Padding: (Horizontal: 12, Vertical: 4);
                                            Text: "+1";
                                            Style: @CustomStyle;
                                        }

                                        Group { Anchor: (Width: 4); }

                                        $C.@TextButton #IntelligencePlus5 {
                                            Anchor: (Height: 28, Width: 46);
                                            Padding: (Horizontal: 12, Vertical: 4);
                                            Text: "+5";
                                            Style: @CustomStyle;
                                        }
                                    }
                                }
                            }
                        }
                    }
                }

                // -------- FOOTER --------
                Group #Footer {
                    LayoutMode: Top;
                    Background: #070b12;

                    Group {
                        Anchor: (Height: 2);
                        Background: #142034;
                    }

                    Group {
                        LayoutMode: Left;
                        Padding: (Full: 20);
                        Background: #0b141f(0.95);
                        Anchor: (Height: 80);

                        Group {
                            LayoutMode: Top;
                            FlexWeight: 1;

                            Label #SKILLPOINTS {
                                Style: (TextColor: #6fe3ff, FontSize: 22, RenderBold: true, VerticalAlignment: Center);
                                Padding: (Bottom: 2);
                                FlexWeight: 1;
                            }

                            Label {
                                Text: "Undo to revert pending tweaks, apply to lock them in.";
                                Style: (TextColor: #c0cee5, FontSize: 12, VerticalAlignment: Center);
                                FlexWeight: 1;
                            }
                        }

                        Group { Anchor: (Width: 20); }

                        Group {
                            LayoutMode: Left;
                            Anchor: (Width: 280);

                            $C.@CancelTextButton #ResetSkills {
                                Text: "UNDO";
                                Anchor: (Height: @PrimaryButtonHeight + 4, Width: 130);
                                Padding: (Horizontal: @ButtonPadding);
                            }

                            Group { Anchor: (Width: 12); }

                            $C.@TextButton #ApplySkills {
                                Text: "APPLY";
                                Anchor: (Height: @PrimaryButtonHeight + 4, Width: 130);
                                Padding: (Horizontal: @ButtonPadding);
                            }
                        }
                    }
                }
            }
        }
    }
}

$C.@BackButton {}
