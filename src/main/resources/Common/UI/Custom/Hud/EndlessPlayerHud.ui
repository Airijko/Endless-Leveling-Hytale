$C = "../Common.ui";

$Hotbar = "Hotbar.ui";
Group {
  LayoutMode: Bottom;
  Anchor: (Bottom: 0, Width: 675, Height: 12);

  Group {
    LayoutMode: Middle;

    Group {
      Anchor: (Left: 0, Width: 675, Height: 12);
      Background: "XPBackground.png";

      ProgressBar #ProgressBar {
        Anchor: (Width: 675, Height: 12);
        BarTexturePath: "XPFill.png";
      }

      ProgressBar #ProgressBarEffect {
        Anchor: (Width: 675, Height: 12);
        BarTexturePath: "XPEffect.png";
      }
    }
  }

  Label #Level {
    Anchor: (Left: 0, Width: 4, Height: 18, Right: 4);
    Style: (FontSize: 12, Alignment: Center);
    Text: "MyText";
  }
}