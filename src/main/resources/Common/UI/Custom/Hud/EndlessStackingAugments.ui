$C = "../Common.ui";

// 6 stacking augment icon slots, horizontally centered above the XP bar.
// Each slot mirrors the same anatomy: background, gold max-stack outline,
// ten category-icon variants (one shown at runtime), stack badge + count.
// Positions (Left within 634px parent, 32px slots with 4px gaps, centered):
//   Slot 0: 211  Slot 1: 247  Slot 2: 283  Slot 3: 319  Slot 4: 355  Slot 5: 391

Group #StackingAugmentsHud {
  Anchor: (Bottom: 159, Width: 634, Height: 32);

  Group #StackingSlot0 {
    Anchor: (Left: 211, Top: 0, Width: 32, Height: 32);
    Visible: false;

    Group #StackingSlot0Background {
      Anchor: (Top: 0, Left: 0, Width: 32, Height: 32);
      Background: #0f1824(0.82);
    }

    Group #StackingSlot0MaxOutline {
      Anchor: (Top: 0, Bottom: 0, Left: 0, Right: 0);
      Visible: false;
      Group { Anchor: (Top: 0, Left: 0, Right: 0, Height: 1); Background: #f0cf78; }
      Group { Anchor: (Top: 0, Bottom: 0, Left: 0, Width: 1); Background: #f0cf78; }
      Group { Anchor: (Top: 0, Bottom: 0, Right: 0, Width: 1); Background: #f0cf78; }
      Group { Anchor: (Bottom: 0, Left: 0, Right: 0, Height: 1); Background: #f0cf78; }
    }

    ItemIcon #StackingSlot0IconCommonStat { ItemId: "Ingredient_Crystal_White"; Anchor: (Width: 32, Height: 32, Left: 0, Top: 0); Visible: false; }
    ItemIcon #StackingSlot0IconPassiveStat { ItemId: "Ingredient_Life_Essence"; Anchor: (Width: 32, Height: 32, Left: 0, Top: 0); Visible: false; }
    ItemIcon #StackingSlot0IconMagicStat { ItemId: "Weapon_Staff_Bronze"; Anchor: (Width: 32, Height: 32, Left: 0, Top: 0); Visible: false; }
    ItemIcon #StackingSlot0IconOnHit { ItemId: "Weapon_Daggers_Fang_Doomed"; Anchor: (Width: 32, Height: 32, Left: 0, Top: 0); Visible: false; }
    ItemIcon #StackingSlot0IconOnRangedHit { ItemId: "Weapon_Shortbow_Crude"; Anchor: (Width: 32, Height: 32, Left: 0, Top: 0); Visible: false; }
    ItemIcon #StackingSlot0IconOnDamageTaken { ItemId: "Weapon_Shield_Orbis_Knight"; Anchor: (Width: 32, Height: 32, Left: 0, Top: 0); Visible: false; }
    ItemIcon #StackingSlot0IconOnLowHp { ItemId: "Potion_Health_Lesser"; Anchor: (Width: 32, Height: 32, Left: 0, Top: 0); Visible: false; }
    ItemIcon #StackingSlot0IconOnCrit { ItemId: "Weapon_Battleaxe_Mithril"; Anchor: (Width: 32, Height: 32, Left: 0, Top: 0); Visible: false; }
    ItemIcon #StackingSlot0IconOnKill { ItemId: "Ingredient_Fire_Essence"; Anchor: (Width: 32, Height: 32, Left: 0, Top: 0); Visible: false; }
    ItemIcon #StackingSlot0IconOnLifesteal { ItemId: "Potion_Health_Greater"; Anchor: (Width: 32, Height: 32, Left: 0, Top: 0); Visible: false; }

    Group #StackingSlot0StackBadge {
      Anchor: (Width: 16, Height: 16, Right: 0, Bottom: 0);
      Background: #000000(0.85);
    }
    Label #StackingSlot0StackCount {
      Anchor: (Width: 16, Height: 16, Right: 0, Bottom: 0);
      Style: (FontSize: 12, Alignment: Center, TextColor: #ffffff, RenderBold: true);
      Text: "1";
    }
  }

